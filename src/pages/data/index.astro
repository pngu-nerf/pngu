---
/**
 * Blaster Data index — lists entries from the `blasters` content collection
 * as project tiles, with client-side search by title.
 *
 * Content comes from `src/content/blasters/*.md(x)`. Today the collection is
 * empty (no entries committed yet); when entries are added, they show up here.
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const blasters = await getCollection('blasters');
blasters.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<MainLayout title="Blaster Data">
  <div class="page-header">
    <div class="label-tag">blaster data</div>
    <h1>Blaster Data</h1>
    <p class="header-subtitle">Documentation & Specifications</p>
    <div class="header-nav">
      <a href="/" class="btn-glass">← Back Home</a>
    </div>
  </div>

  <div class="search-container">
    <input type="text" id="data-search" placeholder="Search blasters..." class="glass-input" />
  </div>

  <div id="results-container">
    {blasters.length === 0 ? (
      <p class="empty-state">
        No blasters added yet. Add entries under <code>src/content/blasters/</code>.
      </p>
    ) : (
      <div class="project-grid">
        {blasters.map((blaster) => (
          <a
            href={`/data/${blaster.id}`}
            class="project-tile"
            data-title={blaster.data.title.toLowerCase()}
          >
            <div class="tile-top">
              <span class="tile-title">{blaster.data.title}</span>
            </div>
            {blaster.data.description && (
              <p class="tile-desc">{blaster.data.description}</p>
            )}
            <span class="tile-arrow">View entry →</span>
          </a>
        ))}
      </div>
    )}
  </div>
</MainLayout>

<style>
  .empty-state {
    color: var(--text-muted);
    font-size: 0.95rem;
    padding: 2rem;
    text-align: center;
    border: 1px dashed var(--glass-border);
    border-radius: var(--glass-radius);
    background: var(--glass-bg);
  }
  .empty-state code {
    font-family: var(--font-mono);
    background: var(--glass-bg-strong);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--text-secondary);
  }
</style>

<script is:inline>
  // Client-side filter on title. There are no letter groups on this page,
  // so we just hide individual tiles.
  (function () {
    const input = document.getElementById('data-search');
    if (!input) return;
    const tiles = document.querySelectorAll('.project-tile');
    input.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      tiles.forEach((tile) => {
        const match = (tile.dataset.title || '').includes(term);
        tile.style.display = match ? 'flex' : 'none';
      });
    });
  })();
</script>
