---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const blasters = await getCollection('blasters');
---

<MainLayout title="Blaster Data">
  <div style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Blaster Library</h1>
    <p style="color: var(--text-muted);">Documentation, specifications, and files for various blasters.</p>
  </div>

  <input 
    type="text" 
    id="search" 
    placeholder="Search blasters..." 
    style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-card); color: white; margin-bottom: 2rem;"
  />

  <div class="grid" id="blaster-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
    {blasters.map(blaster => (
      <a href={`/data/${blaster.slug}`} class="card blaster-card" data-title={blaster.data.title.toLowerCase()}>
        <h2 style="font-size: 1.25rem; margin-bottom: 0.5rem; color: var(--text-main);">{blaster.data.title}</h2>
        {blaster.data.description && <p style="color: var(--text-muted); font-size: 0.9rem;">{blaster.data.description}</p>}
      </a>
    ))}
    {blasters.length === 0 && (
      <p style="color: var(--text-muted);">No blasters added yet. Go to /keystatic to create one!</p>
    )}
  </div>
</MainLayout>

<script is:inline>
  const searchInput = document.getElementById('search');
  const cards = document.querySelectorAll('.blaster-card');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      cards.forEach(card => {
        const title = card.getAttribute('data-title');
        if (title.includes(term)) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  }
</script>
