---
/**
 * Blaster Data entry — review-style detail page driven by the new schema.
 *
 * Layout (top to bottom):
 *   1. Hero image (auto-discovered from R2 <slug>/hero/)
 *   2. Title + tagline
 *   3. Quick-stat infographic grid (only cards with data)
 *   4. FPS spread table (skipped if empty)
 *   5. Nine review sections in fixed order; each renders only if it has a
 *      body OR an auto-discovered gallery under <slug>/galleries/<key>/
 *   6. Verdict block (only if verdict is set)
 *   7. External links grouped by category
 *
 * Galleries are NOT listed in frontmatter — they're discovered at build
 * time by listing R2. Order is alphabetical filename; prefix with 01-,
 * 02-, etc. to control it.
 */
import MainLayout from '../../layouts/MainLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import {
  SECTION_KEYS,
  SECTION_HEADINGS,
  BLASTER_PREFIX,
  heroPrefix,
  galleryPrefix,
  mainGalleryPrefix,
  type SectionKey,
} from '../../lib/blaster-paths';
import { getR2Data, listR2Files } from '../../lib/r2';
import { R2_BASE_URL } from '../../constants';

// Configure marked once. GitHub-flavoured Markdown + breaks so a single
// newline in the editor becomes a <br>. Output is HTML we inject via
// set:html into .markdown-content blocks below.
marked.setOptions({ gfm: true, breaks: true });
const renderMarkdown = (md: string | undefined): string =>
  md ? (marked.parse(md.trim(), { async: false }) as string) : '';

type Galleries = Partial<Record<SectionKey, string[]>>;

export async function getStaticPaths() {
  const blasters = await getCollection('blasters');
  return Promise.all(
    blasters.map(async (blaster) => {
      const slug = blaster.id;

      // 1 call: every file directly under <slug>/hero/
      const heroFiles = await listR2Files(heroPrefix(slug));

      // 1 call: every file under <slug>/galleries/ grouped by section
      const galleryFolders = await getR2Data(`${BLASTER_PREFIX}/${slug}/galleries/`);
      const galleries: Galleries = {};
      for (const folder of galleryFolders) {
        if ((SECTION_KEYS as readonly string[]).includes(folder.folderName)) {
          galleries[folder.folderName as SectionKey] = [...folder.files].sort();
        }
      }

      // 1 call: every file directly under <slug>/gallery/ — the general
      // page-bottom gallery, separate from the per-section galleries.
      const mainGalleryFiles = await listR2Files(mainGalleryPrefix(slug));

      return {
        params: { slug },
        props: { blaster, heroFiles, galleries, mainGalleryFiles },
      };
    })
  );
}

const { blaster, heroFiles, galleries, mainGalleryFiles } = Astro.props as {
  blaster: Awaited<ReturnType<typeof getCollection<'blasters'>>>[number];
  heroFiles: string[];
  galleries: Galleries;
  mainGalleryFiles: string[];
};

const data = blaster.data;

// Pick the hero: requested filename if it exists, else the first
// alphabetical hero file, else undefined (no hero rendered).
const heroFilename = heroFiles.includes(data.heroFilename)
  ? data.heroFilename
  : heroFiles[0];
const heroUrl = heroFilename
  ? `${R2_BASE_URL}/${heroPrefix(blaster.id)}${heroFilename}`
  : undefined;

// Build the URL list once per section so the template stays clean.
function galleryUrls(key: SectionKey): { filename: string; url: string }[] {
  const list = galleries[key] ?? [];
  return list.map((filename) => ({
    filename,
    url: `${R2_BASE_URL}/${galleryPrefix(blaster.id, key)}${filename}`,
  }));
}

// Stats are grouped into labelled panels for scannability. Each panel
// only renders if at least one of its cards has a value.
//
// Filters:
//   numeric / string cards → hide if undefined or empty string
//   boolean pills          → hide if false OR undefined; only `true`
//                            renders as a feature pill
const stats = data.stats ?? {};

type NumCard = { label: string; value: number | string | undefined; prefix?: string; suffix?: string };
const visibleNum = (cards: NumCard[]) =>
  cards.filter((c) => c.value !== undefined && c.value !== '');
const visibleBool = (pills: Array<{ label: string; value: boolean | undefined }>) =>
  pills.filter((p) => p.value === true);

// ── At-a-glance: identity / spec ────────────────────────────────────
const atAGlance = visibleNum([
  { label: 'Type', value: stats.blasterType },
  { label: 'Mag system', value: stats.magSystem },
  { label: 'Battery', value: stats.battery },
  { label: 'Bragging rights', value: stats.braggingRights },
]);

// ── FPS panel ───────────────────────────────────────────────────────
const fpsMaxCard = stats.maxFps !== undefined
  ? { label: 'Max', value: stats.maxFps, suffix: ' fps' } satisfies NumCard
  : null;
const fpsMin = stats.recommendedFpsMin;
const fpsMax = stats.recommendedFpsMax;
const hasFpsRange = fpsMin !== undefined || fpsMax !== undefined;
const hasFpsPanel = fpsMaxCard !== null || hasFpsRange;

// Range bar maths: scale against the wider of {recommendedMax, maxFps}
// so the recommended band and the achieved max share an axis.
const fpsAxisHigh = Math.max(
  fpsMin ?? 0,
  fpsMax ?? 0,
  stats.maxFps ?? 0,
  1
);
const fpsAxisLow = 0;
const pct = (n: number) =>
  Math.max(0, Math.min(100, ((n - fpsAxisLow) / (fpsAxisHigh - fpsAxisLow)) * 100));

// ── Cost panel ──────────────────────────────────────────────────────
const cost = visibleNum([
  { label: 'Kit', value: stats.kitPriceUSD, prefix: '$' },
  { label: 'Total', value: stats.totalPriceUSD, prefix: '$' },
  { label: 'Shipping', value: stats.shippingUSD, prefix: '$' },
]);

// ── Mounting panel ──────────────────────────────────────────────────
const mounting = visibleBool([
  { label: 'Picatinny', value: stats.picatinnyMount },
  { label: 'M-LOK', value: stats.mlocMount },
  { label: 'Sling points', value: stats.slingPoints },
]);

// ── Features (everything else, true-only) ───────────────────────────
const features = visibleBool([
  { label: 'LiPo safe', value: stats.lipoSafe },
  { label: 'Brushless FPS dial', value: stats.brushlessFpsDial },
  { label: 'Adjustable spring compression', value: stats.springPrecompression },
  { label: 'Gravity-drop mags', value: stats.gravityDropMags },
  { label: 'A1-printable', value: stats.a1Printable },
  { label: 'Print: beginner-friendly', value: stats.beginnerFriendlyPrint },
  { label: 'Build: beginner-friendly', value: stats.beginnerFriendlyAssembly },
  { label: 'Catch issues', value: stats.catchIssues },
]);

const hasAnyStat =
  atAGlance.length > 0 ||
  hasFpsPanel ||
  cost.length > 0 ||
  mounting.length > 0 ||
  features.length > 0;

const verdictLabel: Record<NonNullable<typeof data.verdict>, string> = {
  skip: 'Skip',
  niche: 'If you need this niche',
  upgrade: 'Worth the upgrade',
};

// Render the section only if it has body content OR a discovered gallery.
const sectionsToRender = SECTION_KEYS.filter((key) => {
  const body = (data[key] as { body?: string } | undefined)?.body?.trim();
  const gallery = galleries[key] ?? [];
  return Boolean(body) || gallery.length > 0;
});

// Re-render markdown bodies — Astro doesn't auto-render string fields,
// only the entry's main body. We just inject as plain text/markdown
// inside .markdown-content, which has the existing global styling.
// (Markdown is rendered server-side by passing through the content
// pipeline. For simplicity we treat section body as preformatted-ish
// markdown by parsing on render below.)

// Page-bottom general gallery
const mainGalleryItems = mainGalleryFiles.map((filename) => ({
  filename,
  url: `${R2_BASE_URL}/${mainGalleryPrefix(blaster.id)}${filename}`,
}));

// External-links grouping
const linksByCategory = data.links.reduce(
  (acc, link) => {
    (acc[link.category] ??= []).push(link);
    return acc;
  },
  {} as Record<string, Array<{ category: string; label: string; url: string }>>
);
const categoryOrder = ['vendor', 'remix', 'support', 'community', 'printables', 'other'] as const;
const categoryHeading: Record<typeof categoryOrder[number], string> = {
  vendor: 'Vendors',
  remix: 'Remixes',
  support: 'Support',
  community: 'Community',
  printables: 'Printables',
  other: 'Other',
};
---

<MainLayout title={data.title} description={data.designer ? `Designed by ${data.designer}` : undefined}>
  <a href="/data" class="back-link">← All Blasters</a>

  {heroUrl && (
    <div class="hero">
      <OptimizedImage src={heroUrl} size="hero" alt={data.title} class="hero-img" />
      <div class="hero-fade"></div>
    </div>
  )}

  <div class="page-header">
    <div class="label-tag">blaster</div>
    <h1>{data.title}</h1>
    {data.designer && <p class="header-subtitle">Designed by {data.designer}</p>}
  </div>

  {hasAnyStat && (
    <div class="stat-panels">
      {atAGlance.length > 0 && (
        <section class="stat-panel">
          <h3 class="stat-panel-label">At a glance</h3>
          <div class="stat-row">
            {atAGlance.map((s) => (
              <div class="stat-card">
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.prefix}{s.value}{s.suffix}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {hasFpsPanel && (
        <section class="stat-panel">
          <h3 class="stat-panel-label">FPS</h3>
          <div class="stat-row fps-row">
            {fpsMaxCard && (
              <div class="stat-card">
                <span class="stat-label">{fpsMaxCard.label}</span>
                <span class="stat-value">{fpsMaxCard.value}{fpsMaxCard.suffix}</span>
              </div>
            )}
            {hasFpsRange && (
              <div class="stat-card stat-card-wide fps-range-card">
                <span class="stat-label">Recommended range</span>
                <span class="stat-value fps-range-value">
                  {fpsMin !== undefined ? fpsMin : '?'}
                  {' – '}
                  {fpsMax !== undefined ? fpsMax : '?'}
                  <span class="fps-unit">fps</span>
                </span>
                <div class="fps-axis" role="img"
                     aria-label={`Recommended ${fpsMin ?? '?'} to ${fpsMax ?? '?'} fps`}>
                  {fpsMin !== undefined && fpsMax !== undefined && (
                    <span
                      class="fps-band"
                      style={`left: ${pct(fpsMin)}%; right: ${100 - pct(fpsMax)}%;`}
                    ></span>
                  )}
                  {stats.maxFps !== undefined && (
                    <span class="fps-marker" style={`left: ${pct(stats.maxFps)}%;`}
                          title={`Max FPS ${stats.maxFps}`}></span>
                  )}
                </div>
                <div class="fps-axis-labels">
                  <span>0</span>
                  <span>{fpsAxisHigh} fps</span>
                </div>
              </div>
            )}
          </div>
        </section>
      )}

      {cost.length > 0 && (
        <section class="stat-panel">
          <h3 class="stat-panel-label">Cost</h3>
          <div class="stat-row">
            {cost.map((s) => (
              <div class="stat-card">
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.prefix}{s.value}{s.suffix}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {mounting.length > 0 && (
        <section class="stat-panel">
          <h3 class="stat-panel-label">Mounting</h3>
          <div class="stat-row">
            {mounting.map((b) => (
              <div class="stat-card stat-pill on">
                <span class="stat-pill-icon">✓</span>
                <span class="stat-pill-label">{b.label}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {features.length > 0 && (
        <section class="stat-panel">
          <h3 class="stat-panel-label">Features</h3>
          <div class="stat-row">
            {features.map((b) => (
              <div class="stat-card stat-pill on">
                <span class="stat-pill-icon">✓</span>
                <span class="stat-pill-label">{b.label}</span>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  )}

  {sectionsToRender.map((key) => {
    const body = (data[key] as { body?: string } | undefined)?.body?.trim();
    const items = galleryUrls(key);
    return (
      <section class="review-section">
        <h2 class="block-heading">{SECTION_HEADINGS[key]}</h2>
        {body && (
          <div class="markdown-content">
            {/* Section bodies are short markdown snippets. Render raw —
                Astro's MD pipeline isn't easily invoked for arbitrary
                strings, so we use set:html with the raw markdown. For
                more involved bodies, prefer the entry's main body
                field instead. */}
            <Fragment set:html={renderMarkdown(body)} />
          </div>
        )}
        {items.length > 0 && (
          <div class="gallery-grid">
            {items.map((img) => (
              <details class="glass-dropdown gallery-item">
                <summary>
                  <OptimizedImage
                    src={img.url}
                    size="tile"
                    alt={img.filename}
                    class="gallery-thumb"
                  />
                  <span class="gallery-name">{img.filename}</span>
                </summary>
                <div class="preview-wrap">
                  <div class="checkerboard">
                    <OptimizedImage
                      src={img.url}
                      size="hero"
                      alt={img.filename}
                    />
                  </div>
                </div>
              </details>
            ))}
          </div>
        )}
      </section>
    );
  })}

  {data.verdict && (
    <section class:list={['verdict-block', `verdict-${data.verdict}`]}>
      <div class="verdict-tag">Verdict</div>
      <h2 class="verdict-heading">{verdictLabel[data.verdict]}</h2>
      {data.finalHighlights && (
        <div class="markdown-content verdict-block-body">
          <h3>Highlights</h3>
          <Fragment set:html={renderMarkdown(data.finalHighlights)} />
        </div>
      )}
      {data.finalWarnings && (
        <div class="markdown-content verdict-block-body">
          <h3>Warnings</h3>
          <Fragment set:html={renderMarkdown(data.finalWarnings)} />
        </div>
      )}
      {data.verdict === 'niche' && data.betterAlternative && (
        <p class="verdict-alt">
          A blaster that fills this role better: <strong>{data.betterAlternative}</strong>
        </p>
      )}
      {data.closingNote && <p class="verdict-closing">{data.closingNote}</p>}
    </section>
  )}

  {data.links.length > 0 && (
    <section class="links-section">
      <h2 class="block-heading">External links</h2>
      {categoryOrder.map((cat) => {
        const items = linksByCategory[cat] ?? [];
        if (items.length === 0) return null;
        return (
          <div class="link-group">
            <div class="letter-header">{categoryHeading[cat]}</div>
            <ul class="link-list">
              {items.map((l) => (
                <li>
                  <a href={l.url} target="_blank" rel="noopener" class="link-row">
                    {l.label} <span class="link-arrow" aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </section>
  )}

  {mainGalleryItems.length > 0 && (
    <section class="main-gallery">
      <h2 class="block-heading">Gallery</h2>
      <div class="gallery-grid">
        {mainGalleryItems.map((img) => (
          <details class="glass-dropdown gallery-item">
            <summary>
              <OptimizedImage
                src={img.url}
                size="tile"
                alt={img.filename}
                class="gallery-thumb"
              />
              <span class="gallery-name">{img.filename}</span>
            </summary>
            <div class="preview-wrap">
              <div class="checkerboard">
                <OptimizedImage src={img.url} size="hero" alt={img.filename} />
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>
  )}
</MainLayout>

<style>
  .hero {
    position: relative;
    margin: 0 -1.5rem 0;        /* slight bleed past page padding */
    border-radius: var(--glass-radius);
    overflow: hidden;
    max-height: 480px;
  }
  .hero :global(.hero-img) {
    width: 100%;
    height: 100%;
    max-height: 480px;
    object-fit: cover;
    display: block;
  }
  .hero-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.6) 100%);
    pointer-events: none;
  }

  .block-heading {
    font-family: var(--font-title);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  /* ── Stat panels ────────────────────────────────────────────────── */
  .stat-panels {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 1.5rem 0 2rem;
  }
  .stat-panel { display: flex; flex-direction: column; gap: 0.5rem; }
  .stat-panel-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin: 0;
  }
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.6rem;
  }
  .stat-card {
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius-sm);
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-card-wide { grid-column: span 2; }
  @media (max-width: 600px) {
    .stat-card-wide { grid-column: 1 / -1; }
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }
  .stat-value {
    font-family: var(--font-title);
    font-size: 1.4rem;
    color: var(--text-primary);
    line-height: 1.1;
  }
  .stat-pill {
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    border-color: rgba(193, 17, 17, 0.35);
  }
  .stat-pill-icon {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    width: 1.25rem;
    text-align: center;
    color: var(--accent);
  }
  .stat-pill-label {
    font-size: 0.82rem;
    color: var(--text-secondary);
  }

  /* ── FPS range graphic ──────────────────────────────────────────── */
  .fps-row { align-items: stretch; }
  .fps-range-value { display: flex; align-items: baseline; gap: 0.4rem; }
  .fps-unit {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .fps-axis {
    position: relative;
    height: 8px;
    margin: 0.6rem 0 0.25rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 100px;
  }
  .fps-band {
    position: absolute;
    top: 0;
    bottom: 0;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright));
    border-radius: 100px;
    box-shadow: 0 0 12px rgba(193, 17, 17, 0.3);
  }
  .fps-marker {
    position: absolute;
    top: -4px;
    width: 2px;
    height: 16px;
    background: #fff;
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.6);
    transform: translateX(-1px);
  }
  .fps-axis-labels {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  /* ── Main page-bottom gallery ───────────────────────────────────── */
  .main-gallery { margin: 3rem 0; }

  /* ── Review sections + gallery ──────────────────────────────────── */
  .review-section {
    margin: 2.5rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .gallery-item :global(summary) {
    padding: 0;
    flex-direction: column;
    gap: 0;
  }
  .gallery-item :global(.gallery-thumb) {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: var(--glass-radius-sm) var(--glass-radius-sm) 0 0;
  }
  .gallery-name {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Verdict block ──────────────────────────────────────────────── */
  .verdict-block {
    margin: 3rem 0;
    padding: 2rem;
    border-radius: var(--glass-radius);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .verdict-block.verdict-skip { border-color: var(--glass-border); }
  .verdict-block.verdict-niche {
    border-color: rgba(193, 17, 17, 0.3);
    background: linear-gradient(135deg, var(--accent-soft), var(--glass-bg));
  }
  .verdict-block.verdict-upgrade {
    border-color: var(--accent);
    background: linear-gradient(135deg, var(--accent-soft), var(--glass-bg));
    box-shadow: 0 0 40px rgba(193, 17, 17, 0.15);
  }
  .verdict-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .verdict-heading {
    font-family: var(--font-title);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 1rem;
  }
  .verdict-block-body { margin-bottom: 1rem; }
  .verdict-block-body h3 {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .verdict-alt {
    padding: 0.85rem 1rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius-sm);
    font-size: 0.92rem;
    color: var(--text-secondary);
  }
  .verdict-closing {
    margin-top: 1rem;
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* ── External links ─────────────────────────────────────────────── */
  .links-section { margin: 3rem 0; }
  .link-group { margin-bottom: 1.25rem; }
  .link-list { list-style: none; padding: 0; margin: 0; }
  .link-list li { margin-bottom: 0.3rem; }
  .link-row {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.92rem;
    transition: color var(--transition-fast);
  }
  .link-row:hover { color: var(--accent); }
  .link-arrow { color: var(--text-muted); }
  .link-row:hover .link-arrow { color: var(--accent); }
</style>

<style is:global>
  /* Markdown body styling — applied to .markdown-content used by each
     review section. Same family used by the original /data/[slug]. */
