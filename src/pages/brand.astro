---
/**
 * Brand Assets page — flat list of brand files pulled from R2, grouped
 * alphabetically with expandable image previews and client-side search.
 *
 * Page-header, glass-input, letter-header, and the glass-dropdown pattern
 * come from MainLayout.
 */
import MainLayout from '../layouts/MainLayout.astro';
import { getR2Data } from '../lib/r2';
import { R2_BRAND_BASE } from '../constants';

// Each R2 "folder" returned by getR2Data() has a `files: string[]`. We don't
// care about folder boundaries on this page — flatten to a single list.
const projects = await getR2Data('PNGU-Brand-Assets-main/');
const allFiles = projects.flatMap((project) =>
  project.files.map((fileName: string) => ({
    name: fileName,
    fullUrl: `${R2_BRAND_BASE}/${encodeURIComponent(fileName)}`,
  }))
);

// Group by uppercase first letter; non-alphabetic names land in "#".
const grouped = allFiles.reduce(
  (acc, file) => {
    const firstChar = file.name[0]?.toUpperCase() ?? '';
    const key = /^[A-Z]$/.test(firstChar) ? firstChar : '#';
    (acc[key] ??= []).push(file);
    return acc;
  },
  {} as Record<string, typeof allFiles>
);

const sortedLetters = Object.keys(grouped).sort((a, b) => {
  if (a === '#') return 1;
  if (b === '#') return -1;
  return a.localeCompare(b);
});
---

<MainLayout title="Brand Assets">
  <div class="page-header scroll-reveal">
    <div class="label-tag">brand assets</div>
    <h1>Brand Assets</h1>
    <p class="header-subtitle">Logos & Banners</p>
    <div class="header-nav">
      <a href="/" class="btn-glass">← Back Home</a>
    </div>
  </div>

  <div class="search-container scroll-reveal">
    <input type="text" id="brand-search" placeholder="Search assets..." class="glass-input" />
  </div>

  <div id="results-container">
    {sortedLetters.map((letter) => (
      <div class="letter-group scroll-reveal" data-letter={letter}>
        <div class="letter-header">{letter}</div>
        <div class="file-list scroll-reveal-stagger">
          {grouped[letter].map((file) => {
            const isImage = /\.(svg|png|jpg|jpeg|webp)$/i.test(file.name);
            return (
              <details class="glass-dropdown" data-filename={file.name.toLowerCase()}>
                <summary>
                  <div class="summary-header">
                    <span class="file-name">{file.name}</span>
                    <span class="preview-text">Preview</span>
                  </div>
                  <a
                    href={file.fullUrl}
                    class="download-pill"
                    download={file.name}
                    onclick="event.stopPropagation();"
                  >
                    Download
                  </a>
                </summary>
                <div class="preview-wrap">
                  {isImage ? (
                    <div class="checkerboard">
                      <img src={file.fullUrl} alt={file.name} loading="lazy" />
                    </div>
                  ) : (
                    <div class="no-preview">Preview not available</div>
                  )}
                </div>
              </details>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</MainLayout>

<style>
  /* Checkerboard background so transparent assets read clearly */
  .checkerboard {
    background-color: #1a1a1a;
    background-image:
      linear-gradient(45deg,  rgba(255, 255, 255, 0.02) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(255, 255, 255, 0.02) 25%, transparent 25%),
      linear-gradient(45deg,  transparent 75%, rgba(255, 255, 255, 0.02) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255, 255, 255, 0.02) 75%);
    background-size: 20px 20px;
    border-radius: var(--glass-radius-xs);
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    border: 1px solid var(--glass-border);
  }
  .checkerboard img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
  }
  .no-preview {
    text-align: center;
    color: var(--text-muted);
    font-style: italic;
    padding: 2rem;
    font-size: 0.9rem;
  }
</style>

<script is:inline>
  // Client-side filter: hide non-matching files, and hide letter groups that
  // become empty so the alphabetic anchors don't leave dangling headers.
  (function () {
    const input = document.getElementById('brand-search');
    const groups = document.querySelectorAll('.letter-group');
    if (!input) return;
    input.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      groups.forEach((group) => {
        let anyVisible = false;
        group.querySelectorAll('.glass-dropdown').forEach((file) => {
          const match = (file.dataset.filename || '').includes(term);
          file.style.display = match ? 'block' : 'none';
          if (match) anyVisible = true;
        });
        group.style.display = anyVisible ? 'block' : 'none';
      });
    });
  })();
</script>
