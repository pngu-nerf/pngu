---
/**
 * Individual 3D Files project page.
 *
 * Statically generated from R2 listings at build time. Each STL file gets an
 * expandable dropdown that lazy-loads a Three.js viewer when opened.
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getR2Data } from '../../lib/r2';
import { R2_FILES_BASE } from '../../constants';
import { slugify } from '../../lib/slugify';

interface FileRef { name: string; url: string; }

// Declared before getStaticPaths because Astro's frontmatter bundler doesn't
// reliably hoist a function declaration into the getStaticPaths closure.
async function fetchOptionalText(folderName: string, key: string): Promise<string> {
  const url = `${R2_FILES_BASE}/${encodeURIComponent(folderName)}/${key}`;
  try {
    const res = await fetch(url);
    return res.ok ? (await res.text()).trim() : '';
  } catch {
    return '';
  }
}

export async function getStaticPaths() {
  const rawProjects = await getR2Data('PNGU-3D-Files-main/');
  return Promise.all(
    rawProjects.map(async (project) => {
      // description/link are metadata files, not assets.
      const assetFiles = project.files.filter(
        (f: string) => f !== 'description' && f !== 'link'
      );
      const description = await fetchOptionalText(project.folderName, 'description');
      const printablesLink = await fetchOptionalText(project.folderName, 'link');
      return {
        params: { slug: slugify(project.folderName) },
        props: {
          title: project.displayName,
          folderName: project.folderName,
          description,
          printablesLink,
          files: assetFiles.map((fileName: string) => ({
            name: fileName,
            url: `${R2_FILES_BASE}/${encodeURIComponent(project.folderName)}/${encodeURIComponent(fileName)}`,
          })) satisfies FileRef[],
        },
      };
    })
  );
}

const { title, description, printablesLink, files } = Astro.props;
---

<MainLayout title={title}>
  <div class="page-header">
    <a href="/files" class="back-link">← All Files</a>
    <div class="label-tag">3d project</div>
    <h1>{title}</h1>
    {description && <p class="project-desc">{description}</p>}
    {printablesLink && (
      <a href={printablesLink} target="_blank" rel="noopener" class="btn-glass printables-link">
        View on Printables ↗
      </a>
    )}
  </div>

  <div class="file-list">
    {files.map((file: FileRef) => (
      <details class="glass-dropdown" data-stl-url={file.url}>
        <summary>
          <div class="summary-header">
            <span class="file-name">{file.name}</span>
            <span class="preview-text">3D Preview</span>
          </div>
          <a href={file.url} class="download-pill" download onclick="event.stopPropagation();">
            Download STL
          </a>
        </summary>
        <div class="preview-wrap">
          <div class="viewer-container" data-stl-url={file.url}>
            <span class="loading-text">Initializing 3D Engine...</span>
          </div>
        </div>
      </details>
    ))}
  </div>
</MainLayout>

<style>
  .project-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1.5rem;
    white-space: pre-wrap;
  }
  .printables-link { margin-bottom: 1rem; }
  .viewer-container {
    height: 450px;
    width: 100%;
    position: relative;
    background: #1a1a1a;
    border-radius: 0 0 var(--glass-radius-sm) var(--glass-radius-sm);
  }
  .loading-text {
    position: absolute;
    color: var(--text-muted);
    font-size: 0.75rem;
    z-index: 10;
    width: 100%;
    text-align: center;
    padding-top: 200px;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }
  @media (max-width: 640px) {
    .viewer-container { height: 300px; }
  }
</style>

<!-- Three.js for STL previews. Pinned exact version + SRI'd would be safer;
     left at floating-pin for now (see security follow-ups). -->
<script is:inline type="importmap">
  {
    "imports": {
      "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
      "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
    }
  }
</script>

<script is:inline type="module">
  import * as THREE from 'three';
  import { STLLoader } from 'three/addons/loaders/STLLoader.js';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

  // Track which dropdowns we've already wired so toggling doesn't re-init.
  const activeViewers = new WeakSet();

  function initViewer(container, url) {
    if (activeViewers.has(container)) return;
    activeViewers.add(container);

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x111111);
    const camera = new THREE.PerspectiveCamera(
      45,
      container.clientWidth / container.clientHeight,
      0.1,
      1000
    );
    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    scene.add(new THREE.AmbientLight(0xffffff, 1));
    const dirLight = new THREE.DirectionalLight(0xffffff, 2);
    dirLight.position.set(1, 1, 1);
    scene.add(dirLight);

    new STLLoader().load(
      url,
      (geo) => {
        const loadingText = container.querySelector('.loading-text');
        if (loadingText) loadingText.style.display = 'none';
        geo.center();
        const mesh = new THREE.Mesh(
          geo,
          new THREE.MeshPhongMaterial({ color: 0xc11111, specular: 0x222222, shininess: 80 })
        );
        mesh.rotation.x = -Math.PI / 2;
        scene.add(mesh);
        geo.computeBoundingBox();
        const size = Math.max(
          geo.boundingBox.max.x - geo.boundingBox.min.x,
          geo.boundingBox.max.y - geo.boundingBox.min.y
        );
        camera.position.z = size * 2.5;
        (function animate() {
          requestAnimationFrame(animate);
          controls.update();
          renderer.render(scene, camera);
        })();
      },
      undefined,
      () => {
        const loadingText = container.querySelector('.loading-text');
        if (loadingText) loadingText.innerText = 'Error loading 3D model';
      }
    );
  }

  // Lazy-init each viewer the first time its <details> opens. The slight
  // setTimeout lets the open animation start before we hit the GPU.
  document.addEventListener(
    'toggle',
    (e) => {
      const target = e.target;
      if (!target.open || !target.classList.contains('glass-dropdown')) return;
      const viewer = target.querySelector('.viewer-container');
      if (viewer) setTimeout(() => initViewer(viewer, viewer.dataset.stlUrl), 50);
    },
    true
  );
</script>
