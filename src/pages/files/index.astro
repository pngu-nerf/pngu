---
/**
 * 3D Files listing page — fetches project folders from R2 storage,
 * groups them alphabetically, and renders a searchable tile grid.
 * Each tile links to the individual project detail page (/files/[slug]).
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getR2Data } from '../../lib/r2';
import { R2_FILES_BASE } from '../../constants';
import { slugify } from '../../lib/slugify';

let projects: {
  title: string;
  slug: string;
  folderName: string;
  description: string;
  printablesLink: string;
  fileCount: number;
}[] = [];

try {
  const rawProjects = await getR2Data("PNGU-3D-Files-main/");

  // For each project folder, fetch description and external link metadata
  projects = await Promise.all(rawProjects.map(async (project) => {
    const assetFiles = project.files.filter((f: string) => f !== 'description' && f !== 'link');

    let descriptionText = "";
    if (project.files.includes('description')) {
      try {
        const res = await fetch(`${R2_FILES_BASE}/${encodeURIComponent(project.folderName)}/description`);
        if (res.ok) descriptionText = await res.text();
      } catch { descriptionText = ""; }
    }

    let externalLink = "";
    if (project.files.includes('link')) {
      try {
        const res = await fetch(`${R2_FILES_BASE}/${encodeURIComponent(project.folderName)}/link`);
        if (res.ok) externalLink = await res.text();
      } catch { externalLink = ""; }
    }

    return {
      title: project.displayName,
      slug: slugify(project.folderName),
      folderName: project.folderName,
      description: descriptionText.trim(),
      printablesLink: externalLink.trim(),
      fileCount: assetFiles.length,
    };
  }));

  projects.sort((a, b) => a.title.localeCompare(b.title));
} catch (e) {
  console.error("R2 Fetch Error:", e);
}

// Group projects alphabetically by first character
const grouped = projects.reduce((acc, project) => {
  const char = project.title[0].toUpperCase();
  const key = /[A-Z]/.test(char) ? char : "#";
  if (!acc[key]) acc[key] = [];
  acc[key].push(project);
  return acc;
}, {} as Record<string, typeof projects>);

// Sort letter groups with "#" (non-alpha) at the end
const sortedLetters = Object.keys(grouped).sort((a, b) => {
  if (a === "#") return 1;
  if (b === "#") return -1;
  return a.localeCompare(b);
});
---

<MainLayout title="3D Files">
  <div class="page-header">
    <div class="label-tag">3d files</div>
    <h1>3D Files</h1>
    <p class="header-subtitle">Component & Blaster Models</p>
    <div class="header-nav">
      <a href="/" class="btn-glass">← Back Home</a>
      <a href="https://lite.pngu.info/files/" class="btn-glass">Lite Version</a>
    </div>
  </div>

  <!-- Search filter -->
  <div class="search-container">
    <input type="text" id="file-search" placeholder="Search projects..." class="glass-input" />
  </div>

  <!-- Alphabetically grouped project tiles -->
  <div id="results-container">
    {sortedLetters.map((letter) => (
      <div class="letter-group scroll-reveal" data-letter={letter}>
        <div class="letter-header">{letter}</div>
        <div class="project-grid scroll-reveal-stagger">
          {grouped[letter].map((project) => (
            <a href={`/files/${project.slug}`} class="project-tile" data-title={project.title.toLowerCase()}>
              <div class="tile-top">
                <span class="tile-title">{project.title}</span>
                <span class="tile-count">{project.fileCount} file{project.fileCount !== 1 ? 's' : ''}</span>
              </div>
              {project.description && (
                <p class="tile-desc">{project.description.slice(0, 80)}{project.description.length > 80 ? '…' : ''}</p>
              )}
              <span class="tile-arrow">View project →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</MainLayout>

<!-- Client-side search: filters project tiles by title -->
<script is:inline>
  var searchInput = document.getElementById('file-search');
  var letterGroups = document.querySelectorAll('.letter-group');

  searchInput.addEventListener('input', function(e) {
    var term = e.target.value.toLowerCase();
    letterGroups.forEach(function(group) {
      var hasVisible = false;
      var tiles = group.querySelectorAll('.project-tile');
      tiles.forEach(function(tile) {
        var title = tile.dataset.title;
        if (title.includes(term)) {
          tile.style.display = 'flex';
          hasVisible = true;
        } else {
          tile.style.display = 'none';
        }
      });
      group.style.display = hasVisible ? 'block' : 'none';
    });
  });
</script>
