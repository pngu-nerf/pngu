---
/**
 * 3D Files index — project tiles pulled from R2, grouped alphabetically.
 * Each tile links to /files/[slug].
 *
 * The R2 folder layout per project is:
 *   <projectName>/<asset files...>
 *   <projectName>/description   ← optional, served as text
 *   <projectName>/link          ← optional, external project URL
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getR2Data } from '../../lib/r2';
import { R2_FILES_BASE } from '../../constants';
import { slugify } from '../../lib/slugify';

interface Project {
  title: string;
  slug: string;
  folderName: string;
  description: string;
  printablesLink: string;
  fileCount: number;
}

// Declared before the top-level await below so Astro's frontmatter bundler
// can see it — function-declaration hoisting isn't reliable across the
// boundary that wraps top-level async work.
async function fetchOptionalText(folderName: string, key: string): Promise<string> {
  const url = `${R2_FILES_BASE}/${encodeURIComponent(folderName)}/${key}`;
  try {
    const res = await fetch(url);
    return res.ok ? (await res.text()).trim() : '';
  } catch {
    return '';
  }
}

let projects: Project[] = [];

try {
  const rawProjects = await getR2Data('PNGU-3D-Files-main/');

  projects = await Promise.all(
    rawProjects.map(async (project): Promise<Project> => {
      const assetFiles = project.files.filter(
        (f: string) => f !== 'description' && f !== 'link'
      );
      const description = await fetchOptionalText(project.folderName, 'description');
      const printablesLink = await fetchOptionalText(project.folderName, 'link');
      return {
        title: project.displayName,
        slug: slugify(project.folderName),
        folderName: project.folderName,
        description,
        printablesLink,
        fileCount: assetFiles.length,
      };
    })
  );

  projects.sort((a, b) => a.title.localeCompare(b.title));
} catch (err) {
  console.error('R2 fetch failed for /files index:', err);
}

// Group projects by uppercase first letter; non-alphabetic titles land in "#".
const grouped = projects.reduce(
  (acc, project) => {
    const firstChar = project.title[0]?.toUpperCase() ?? '';
    const key = /^[A-Z]$/.test(firstChar) ? firstChar : '#';
    (acc[key] ??= []).push(project);
    return acc;
  },
  {} as Record<string, Project[]>
);

const sortedLetters = Object.keys(grouped).sort((a, b) => {
  if (a === '#') return 1;
  if (b === '#') return -1;
  return a.localeCompare(b);
});
---

<MainLayout title="3D Files">
  <div class="page-header scroll-reveal">
    <div class="label-tag">3d files</div>
    <h1>3D Files</h1>
    <p class="header-subtitle">Component & Blaster Models</p>
    <div class="header-nav">
      <a href="/" class="btn-glass">← Back Home</a>
    </div>
  </div>

  <div class="search-container scroll-reveal">
    <input type="text" id="file-search" placeholder="Search projects..." class="glass-input" />
  </div>

  <div id="results-container">
    {sortedLetters.map((letter) => (
      <div class="letter-group scroll-reveal" data-letter={letter}>
        <div class="letter-header">{letter}</div>
        <div class="project-grid scroll-reveal-stagger">
          {grouped[letter].map((project) => (
            <a
              href={`/files/${project.slug}`}
              class="project-tile"
              data-title={project.title.toLowerCase()}
            >
              <div class="tile-top">
                <span class="tile-title">{project.title}</span>
                <span class="tile-count">
                  {project.fileCount} file{project.fileCount !== 1 ? 's' : ''}
                </span>
              </div>
              {project.description && (
                <p class="tile-desc">
                  {project.description.slice(0, 80)}
                  {project.description.length > 80 ? '…' : ''}
                </p>
              )}
              <span class="tile-arrow">View project →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</MainLayout>

<script is:inline>
  // Client-side filter on project title; hides empty letter groups.
  (function () {
    const input = document.getElementById('file-search');
    const groups = document.querySelectorAll('.letter-group');
    if (!input) return;
    input.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      groups.forEach((group) => {
        let anyVisible = false;
        group.querySelectorAll('.project-tile').forEach((tile) => {
          const match = (tile.dataset.title || '').includes(term);
          tile.style.display = match ? 'flex' : 'none';
          if (match) anyVisible = true;
        });
        group.style.display = anyVisible ? 'block' : 'none';
      });
    });
  })();
</script>
