---
/**
 * Contact page — email + Discord cards with copy-to-clipboard.
 * The glass-card / page-header primitives come from MainLayout.
 */
import MainLayout from '../layouts/MainLayout.astro';
import ContactItem from '../components/ContactItem.astro';
---

<MainLayout title="Contact">
  <div class="page-header">
    <div class="label-tag">contact</div>
    <h1>Get in Touch</h1>
    <p class="header-subtitle">Reach out for collaborations or questions</p>
    <div class="header-nav">
      <a href="/" class="btn-glass">← Back</a>
    </div>
  </div>

  <div class="glass-card contact-card" style="animation-delay: 0.1s">
    <h2>Email Address</h2>
    <p class="section-desc">For professional inquiries and partnerships.</p>
    <ContactItem buttonId="copy-email-btn" value="contact@pngu.info" label="Copy Email" />
  </div>

  <div class="glass-card contact-card" style="animation-delay: 0.25s">
    <h2>Discord</h2>
    <p class="section-desc">For casual chats and community contact.</p>
    <ContactItem buttonId="copy-discord-btn" value="penguinnoly" label="Copy Handle" />
  </div>
</MainLayout>

<style>
  .contact-card { margin-bottom: 1.5rem; }
  .section-desc {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 640px) {
    .header-nav { flex-direction: column; }
  }
</style>
