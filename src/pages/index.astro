---
/**
 * Home page — flat directory of sections, no animations, no hero theatrics.
 *
 * Layout:
 *   1. Header (label + h1 + tagline)
 *   2. Two primary section rows: Files, Data — the actual content of the site
 *   3. Secondary row: Brand, Contact — site-meta links
 *
 * External links (YouTube/GitHub/Printables) live in the global footer now;
 * the sitemap there also covers every section, so there's no need to
 * duplicate them inline.
 */
import MainLayout from '../layouts/MainLayout.astro';

const PRIMARY = [
  { href: '/files', name: 'Files', desc: '3D models and STLs' },
  { href: '/data',  name: 'Data',  desc: 'Blaster specs and documentation' },
];

const SECONDARY = [
  { href: '/brand',   label: 'Brand' },
  { href: '/contact', label: 'Contact' },
];
---

<MainLayout title="Home">
  <div class="page-header">
    <div class="label-tag">pngu.info</div>
    <h1>Open-Source Blaster Resources</h1>
    <p class="header-subtitle">
      Files, data, and assets for the Nerf modding community.
    </p>
  </div>

  <nav class="sections" aria-label="Site sections">
    {PRIMARY.map((s) => (
      <a href={s.href} class="section-row">
        <span class="section-name">{s.name}</span>
        <span class="section-desc">{s.desc}</span>
        <span class="section-arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </nav>

  <nav class="secondary" aria-label="More">
    {SECONDARY.map((s) => (
      <a href={s.href}>{s.label}</a>
    ))}
  </nav>
</MainLayout>

<style>
  /* ============================================================
     Primary section list — flat rows, underline-on-hover
     ============================================================ */
  .sections {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--glass-border);
    margin: 2rem 0;
  }
  .section-row {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1rem 0.25rem;
    border-bottom: 1px solid var(--glass-border);
    text-decoration: none;
    color: var(--text-primary);
    transition: background var(--transition-fast),
      color var(--transition-fast);
  }
  @media (hover: hover) {
    .section-row:hover {
      background: var(--glass-bg);
      color: var(--accent);
    }
    .section-row:hover .section-arrow { color: var(--accent); }
  }
  .section-name {
    font-family: var(--font-title);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .section-arrow {
    color: var(--text-muted);
    font-size: 1.1rem;
    transition: color var(--transition-fast);
  }

  /* ============================================================
     Secondary row — Brand · Contact, slim text links
     ============================================================ */
  .secondary {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
    font-size: 0.9rem;
    flex-wrap: wrap;
  }
  .secondary a {
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast),
      border-color var(--transition-fast);
  }
  .secondary a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 640px) {
    .section-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      row-gap: 0.25rem;
    }
    .section-name { grid-column: 1; grid-row: 1; }
    .section-desc { grid-column: 1; grid-row: 2; }
    .section-arrow { grid-column: 2; grid-row: 1 / span 2; align-self: center; }
  }
</style>
