---
/**
 * index.astro — PNGU homepage
 *
 * Layout sections (top to bottom):
 * 1. 3D Zoom Scene (450vh total scroll space)
 * - Front: Hero Section
 * - Middle: Frosted Glass Penguin Portal
 * - Back: Highlight White Zone (Cinematic Video)
 * 2. Highlight Details (Flows seamlessly below the 3D scene)
 * 3. Fade to Aurora
 */
import MainLayout from '../layouts/MainLayout.astro';
import { getR2Data } from '../lib/r2';
import { R2_HIGHLIGHT_BASE } from '../constants';

// ── Fetch highlight data from R2 bucket ──
let highlightTitle = "";
let highlightDescription = "";

try {
  const highlightProjects = await getR2Data("highlight/");
  for (const project of highlightProjects) {
    const folder = project.folderName === "." ? "" : `/${encodeURIComponent(project.folderName)}`;
    const base = `${R2_HIGHLIGHT_BASE}${folder}`;
    const files = project.files as string[];

    if (files.includes("title")) {
      try {
        const res = await fetch(`${base}/title`);
        if (res.ok) highlightTitle = (await res.text()).trim();
      } catch { /* fallback */ }
    }
    if (files.includes("description")) {
      try {
        const res = await fetch(`${base}/description`);
        if (res.ok) highlightDescription = (await res.text()).trim();
      } catch { /* fallback */ }
    }
  }
} catch (e) {
  console.error("[Highlight] R2 fetch error:", e);
}

const descriptionLines = highlightDescription
  ? highlightDescription.split("\n").filter(Boolean)
  : [];
---

<MainLayout title="Home">
  
  <div class="zoom-scene" id="zoom-scene">
    <div class="sticky-container">
      <div class="world" id="world">
        
        <div class="layer layer-highlight" id="layer-highlight">
          <div class="highlight-star-flood" id="highlight-star-flood" aria-hidden="true"></div>
          
          <div class="highlight-content">
            <h2 class="highlight-heading scroll-reveal">Highlight</h2>

            <div class="highlight-render-card cinematic-box" id="highlight-render">
              <img
                id="cinematic-sequence"
                src=""
                alt="Cinematic Scroll Animation"
                class="highlight-render-media"
              />
              <div class="highlight-render-placeholder" id="cinematic-placeholder">
                <span>60-Frame Sequence Loading</span>
              </div>
            </div>
          </div>
        </div>

        <div class="layer layer-window" id="layer-window">
          <div class="glass-wall" id="glass-wall"></div>
        </div>

        <div class="layer layer-hero" id="layer-hero">
          <div class="landing-fold">
            <section class="hero">
              <h1 class="hero-title">
                <span class="hero-get">Get</span>
                <span class="hero-word-wrap">
                  <span class="hero-reel" id="hero-reel">
                    <span class="reel-word">files</span>
                    <span class="reel-word">data</span>
                    <span class="reel-word">cad</span>
                    <span class="reel-word">stls</span>
                    <span class="reel-word">code</span>
                    <span class="reel-word">mods</span>
                    <span class="reel-word">parts</span>
                    <span class="reel-word">specs</span>
                    <span class="reel-word">plans</span>
                    <span class="reel-word">ideas</span>
                    <span class="reel-word">tools</span>
                    <span class="reel-word">props</span>
                    <span class="reel-word">assets</span>
                    <span class="reel-word">models</span>
                    <span class="reel-word">prints</span>
                    <span class="reel-word">guides</span>
                    <span class="reel-word">stuff</span>
                    <span class="reel-word reel-final">info</span>
                  </span>
                </span>
              </h1>
              <p class="hero-question">What do you need?</p>
            </section>

            <section class="nav-section scroll-reveal">
              <div class="nav-cards" id="nav-cards">
                <a href="/files" class="nav-pill" data-phase="0">
                  <span class="pill-icon">◇</span>
                  <span class="pill-label">3D Files</span>
                  <span class="pill-arrow">→</span>
                </a>
                <a href="/data" class="nav-pill" data-phase="0.7">
                  <span class="pill-icon">◈</span>
                  <span class="pill-label">Blaster Data</span>
                  <span class="pill-arrow">→</span>
                </a>
                <a href="/brand" class="nav-pill" data-phase="1.4">
                  <span class="pill-icon">○</span>
                  <span class="pill-label">Brand Assets</span>
                  <span class="pill-arrow">→</span>
                </a>
                <a href="/contact" class="nav-pill" data-phase="2.1">
                  <span class="pill-icon">◎</span>
                  <span class="pill-label">Contact</span>
                  <span class="pill-arrow">→</span>
                </a>
              </div>
            </section>

            <section class="links-section scroll-reveal">
              <div class="label-tag" id="explore-tag" data-phase="0.5">External links</div>
              <div class="ext-row" id="ext-row">
                <a href="https://www.youtube.com/@PnguNerf" target="_blank" rel="noopener" class="ext-chip" data-phase="0.3">
                  YouTube ↗
                </a>
                <a href="https://github.com/pngu-nerf" target="_blank" rel="noopener" class="ext-chip" data-phase="1.0">
                  GitHub ↗
                </a>
                <a href="https://www.printables.com/@PnguNerf_3188348" target="_blank" rel="noopener" class="ext-chip" data-phase="1.7">
                  Printables ↗
                </a>
              </div>
            </section>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="highlight-white-zone">
    <div class="highlight-white-inner">
      <div class="highlight-info scroll-reveal">
        <h2 class="highlight-project-title">
          {highlightTitle || "Project Title"}
        </h2>
        {descriptionLines.length > 0
          ? descriptionLines.map((line) => (
              <p class="highlight-project-desc">{line}</p>
            ))
          : (
            <>
              <p class="highlight-project-desc">Project Description</p>
              <p class="highlight-project-desc">Project Description</p>
            </>
          )
        }
      </div>
    </div>
  </div>

  <div class="highlight-fade-out"></div>

</MainLayout>

<style>
  /* ── 3D Scene Architecture ── */
  .zoom-scene {
    height: 450vh; /* Runway: 200vh zoom + 150vh scrub + 100vh view */
    position: relative;
    z-index: 10;
  }

  .sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    perspective: 1000px; /* The camera lens */
    z-index: 1;
  }

  .world {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    will-change: transform;
    pointer-events: none; /* Let clicks pass through to layers */
  }

  .layer {
    position: absolute;
    inset: 0;
    width: 100vw;
    height: 100vh;
    transform-style: preserve-3d;
  }

  /* ── Front Layer: Hero ── */
  .layer-hero {
    transform: translateZ(0px);
    pointer-events: auto; /* Clickable */
    will-change: opacity;
  }

  .landing-fold {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-top: -2rem;
  }

  .hero { padding: 0 0 3rem; text-align: center; }
  .hero-word-wrap {
    display: inline-block;
    text-align: left;
    position: relative;
    height: 1.1em;
    overflow: visible;
    clip-path: inset(-2% -50vw -2% 0);
    vertical-align: baseline;
    width: 2.7em; 
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  /* ── Middle Layer: The Penguin Window ── */
  .layer-window {
    transform: translateZ(-1000px);
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: opacity;
  }

  .glass-wall {
    position: absolute;
    left: -100vw;
    top: -100vh;
    width: 300vw;
    height: 300vh;
    background: rgba(10, 10, 15, 0.85); /* Deep dark frost */
    backdrop-filter: blur(15px); /* Defrosts via JS */
    will-change: backdrop-filter;
    
    /* Perfect CSS Hole Punch using mask composites */
    -webkit-mask-image: url('/brand-assets/PNGU-logo-white.svg'), linear-gradient(#fff, #fff);
    -webkit-mask-size: 25vmin, 100% 100%;
    -webkit-mask-position: center, center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-composite: source-out;
    mask-composite: exclude;
  }

  /* ── Back Layer: Highlight (The bright void inside the portal) ── */
  .layer-highlight {
    transform: translateZ(-2000px);
    background: #ffffff;
    box-shadow: 0 0 0 50vw #ffffff; /* Fills extreme viewport edges during 3D travel */
    display: flex;
    flex-direction: column;
    justify-content: center;
    pointer-events: auto;
    opacity: 0; /* Fades in during approach */
    will-change: opacity;
  }

  .highlight-content {
    position: relative;
    z-index: 2;
    width: 100vw;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .highlight-heading {
    font-family: var(--font-title);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000000; /* Black on white */
    margin-bottom: 2rem;
    line-height: 1;
    text-align: center;
  }

  /* ── Cinematic Full Bleed Box ── */
  .highlight-render-card.cinematic-box {
    width: 100vw;
    aspect-ratio: 21 / 9;
    border-radius: 0; /* Edge to edge */
    background: #e0e0e0;
    position: relative;
    overflow: hidden;
  }

  .highlight-render-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
  }

  .highlight-render-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .highlight-render-placeholder span {
    font-family: var(--font-title);
    font-size: clamp(1.5rem, 4vw, 3rem);
    color: rgba(0, 0, 0, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── Star Flood (Inside the Highlight Portal) ── */
  .highlight-star-flood {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
  }

  /* ── Bottom White Zone & Fade Out ── */
  .highlight-white-zone {
    position: relative;
    z-index: 10;
    background: #ffffff;
    padding: 1rem 0 3rem;
  }

  .highlight-white-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .highlight-info { padding: 0; }
  .highlight-project-title {
    font-family: var(--font-title);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #000000;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }
  .highlight-project-desc {
    font-family: var(--font-title);
    font-size: clamp(0.85rem, 2vw, 1.15rem);
    color: #444444;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
    line-height: 1.5;
  }

  .highlight-fade-out {
    position: relative;
    z-index: 10;
    height: 30vh;
    background: linear-gradient(to bottom, #ffffff 0%, transparent 100%);
  }

  @media (max-width: 640px) {
    .highlight-heading { font-size: 2.5rem; }
    .highlight-project-title { font-size: 1.8rem; }
  }
</style>

<script is:inline>
  // ============================================
  //  THE 3D CAMERA ENGINE (Zoom + Defrost + Scrub)
  // ============================================
  (function() {
    var world = document.getElementById('world');
    var glassWall = document.getElementById('glass-wall');
    var layerHero = document.getElementById('layer-hero');
    var layerHighlight = document.getElementById('layer-highlight');
    
    var img = document.getElementById('cinematic-sequence');
    var placeholder = document.getElementById('cinematic-placeholder');
    var totalFrames = 60;

    // 👇 Replace with your actual frame path 👇
    function getFrameUrl(frameNum) {
      return `/animation/frame_${frameNum}.jpg`; 
    }

    // Preload first batch to prevent flashes
    for(var i = 1; i <= 15; i++) {
      var pre = new Image();
      pre.src = getFrameUrl(i);
    }
    if (img) img.src = getFrameUrl(1);
    if (img) img.onload = function() { if(placeholder) placeholder.style.display = 'none'; };

    window.addEventListener('scroll', function() {
      var vh = window.innerHeight;
      var y = window.scrollY;
      
      // --- PHASE 1: 3D PORTAL ZOOM (0 to 200vh) ---
      var zoomEnd = vh * 2;
      var zoomP = Math.max(0, Math.min(1, y / zoomEnd));
      
      // Camera moves from Z=0 to Z=2000
      var cameraZ = zoomP * 2000;
      if (world) world.style.transform = 'translateZ(' + cameraZ + 'px)';
      
      // Defrost the glass as we approach the window (Z=1000)
      var windowProximity = Math.max(0, Math.min(1, (cameraZ - 400) / 600));
      if (glassWall) glassWall.style.backdropFilter = 'blur(' + (15 * (1 - windowProximity)) + 'px)';
      
      // Fade out Hero layer so it doesn't clip the camera, disable clicks when invisible
      var heroOpacity = 1 - Math.max(0, Math.min(1, (cameraZ - 400) / 400));
      if (layerHero) {
        layerHero.style.opacity = heroOpacity;
        layerHero.style.pointerEvents = heroOpacity < 0.1 ? 'none' : 'auto';
      }
      
      // Fade in Highlight layer so it glows gracefully in the distance
      if (layerHighlight) layerHighlight.style.opacity = Math.max(0, Math.min(1, (cameraZ - 500) / 1000));
      
      // Hard hide the glass wall once we pass perfectly through to avoid weird edge clipping bugs
      if (glassWall) glassWall.style.opacity = cameraZ > 1950 ? 0 : 1;


      // --- PHASE 2: CINEMATIC VIDEO SCRUB (200vh to 350vh) ---
      // The scrub only starts calculating AFTER we finish zooming through the hole
      var scrubStart = vh * 2;
      var scrubDuration = vh * 1.5;
      var scrubP = 0;
      
      if (y > scrubStart) {
        scrubP = (y - scrubStart) / scrubDuration;
      }
      scrubP = Math.max(0, Math.min(1, scrubP));
      
      if (img) {
        var frame = Math.max(1, Math.min(totalFrames, Math.ceil(scrubP * totalFrames)));
        var targetSrc = getFrameUrl(frame);
        // Only trigger DOM update if the frame actually changed
        if (img.getAttribute('src') !== targetSrc) {
          img.setAttribute('src', targetSrc);
        }
      }
    }, { passive: true });
  })();

  // ============================================
  //  SLOT MACHINE REEL
  // ============================================
  (function() {
    var reel = document.getElementById('hero-reel');
    if (!reel) return;
    var words = reel.querySelectorAll('.reel-word');
    var totalWords = words.length;
    if (totalWords === 0) return;

    var wordH = words[0].offsetHeight;
    var lastIdx = totalWords - 1;

    function getDelay(idx) {
      var t = idx / lastIdx;
      var curve = Math.sin(t * (Math.PI / 2));
      return 10 + curve * 180; 
    }

    function scrollToWord(idx) {
      var offset = idx * wordH;
      if (idx < lastIdx) {
        var delay = getDelay(idx);
        reel.style.transition = 'transform ' + delay + 'ms linear';
        reel.style.transform = 'translateY(-' + offset + 'px)';
        setTimeout(function() { scrollToWord(idx + 1); }, delay);
      } else {
        reel.style.transition = 'transform 600ms cubic-bezier(0.25, 1.2, 0.5, 1)';
        reel.style.transform = 'translateY(-' + offset + 'px)';
      }
    }

    setTimeout(function() { scrollToWord(1); }, 400);
  })();

  // ============================================
  //  FLOATING SINE WAVE — nav pills
  // ============================================
  (function() {
    var pills = document.querySelectorAll('#nav-cards .nav-pill');
    var chips = document.querySelectorAll('#ext-row .ext-chip');
    var exploreTag = document.getElementById('explore-tag');
    var all = [].slice.call(pills).concat([].slice.call(chips));
    if (exploreTag) all.push(exploreTag);

    var startTime = performance.now();
    var SETTLE = 6000;
    var MIN_AMP = 0.4;

    function animateFloat(time) {
      var elapsed = time - startTime;
      var decay = Math.max(MIN_AMP / 5, 1 - elapsed / SETTLE);
      var amplitude = 5 * decay;
      
      all.forEach(function(el) {
        var phase = parseFloat(el.dataset.phase || '0');
        var y = Math.sin(time * 0.0015 + phase) * amplitude;
        el.style.transform = 'translateY(' + y.toFixed(2) + 'px)';
      });
      requestAnimationFrame(animateFloat);
    }
    requestAnimationFrame(animateFloat);
  })();

  // ============================================
  //  INTERACTIVE STAR FLOOD (Dark Stars on White)
  // ============================================
  (function() {
    var container = document.getElementById('highlight-star-flood');
    if (!container) return;

    var canvas = document.createElement('canvas');
    canvas.style.width = '100%';
    canvas.style.height = '100%';
    container.appendChild(canvas);
    var ctx = canvas.getContext('2d');

    var W, H;
    function resize() {
      W = canvas.width = container.clientWidth;
      H = canvas.height = container.clientHeight;
      buildFloodStars();
    }

    var floodStars = [];
    function buildFloodStars() {
      floodStars = [];
      var spacing = 40;
      for (var x = spacing / 2; x < W; x += spacing) {
        for (var y = spacing / 2; y < H; y += spacing) {
          floodStars.push({
            baseX: x, baseY: y,
            size: 2.0 + Math.random() * 2.5,
            twinkle: Math.random() * Math.PI * 2
          });
        }
      }
    }

    resize();
    window.addEventListener('resize', resize);
    
    var mouseX = -1000, mouseY = -1000;
    window.addEventListener('mousemove', function(e) {
      var rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    var lastFrame = 0;
    function animate(now) {
      requestAnimationFrame(animate);
      if (now - lastFrame < 33) return;
      lastFrame = now;

      ctx.clearRect(0, 0, W, H);

      var mouseInf = 80;
      var mouseInfSq = mouseInf * mouseInf;
      ctx.fillStyle = 'rgba(0, 0, 0, 0.15)'; // Dark stars
      ctx.beginPath();
      
      for (var i = 0; i < floodStars.length; i++) {
        var s = floodStars[i];
        var sx = s.baseX;
        var sy = s.baseY;
        
        var mdx = sx - mouseX;
        var mdy = sy - mouseY;
        var mDistSq = mdx * mdx + mdy * mdy;
        
        if (mDistSq < mouseInfSq && mDistSq > 0) {
          var mDist = Math.sqrt(mDistSq);
          var force = (1 - mDist / mouseInf) * 15;
          sx += (mdx / mDist) * force;
          sy += (mdy / mDist) * force;
        }
        
        var alpha = 0.5 + 0.5 * Math.sin(now * 0.002 + s.twinkle);
        ctx.moveTo(sx + s.size, sy);
        ctx.arc(sx, sy, s.size * alpha, 0, Math.PI * 2);
      }
      ctx.fill();
    }

    requestAnimationFrame(animate);
  })();
</script>
