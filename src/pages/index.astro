---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <div style="text-align: center; padding: 4rem 0 6rem;">
    <h1 style="font-size: 4rem; line-height: 1.1; margin-bottom: 1.5rem; font-weight: 800;">
      Open-Source<br/> <span style="color: var(--accent);">Blaster Resources</span>
    </h1>
    <p style="color: var(--text-muted); font-size: 1.2rem; max-width: 600px; margin: 0 auto 3rem;">
      Get files, data, cad, stls, code, mods, parts, specs, plans, ideas, tools, props, assets, models, prints, and guides.
    </p>

    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/files" class="btn">3D Files</a>
      <a href="/data" class="btn" style="background: var(--bg-card); border: 1px solid var(--border);">Blaster Data</a>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
    <a href="https://www.youtube.com/@PnguNerf" target="_blank" class="card">
      <h3 style="margin-bottom: 0.5rem;">YouTube ↗</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem;">Watch builds, guides, and gameplay.</p>
    </a>
    <a href="https://github.com/pngu-nerf" target="_blank" class="card">
      <h3 style="margin-bottom: 0.5rem;">GitHub ↗</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem;">Source code and open hardware repositories.</p>
    </a>
    <a href="https://www.printables.com/@PnguNerf_3188348" target="_blank" class="card">
      <h3 style="margin-bottom: 0.5rem;">Printables ↗</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem;">Download ready-to-print STLs.</p>
    </a>
  </div>
</MainLayout>
