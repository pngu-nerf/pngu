---
/**
 * index.astro — PNGU homepage
 *
 * Layout sections (top to bottom):
 * 1. Hero — "Get ____" slot machine reel cycling through words, landing on "info"
 * 2. Nav Cards — Floating pill links to Files, Data, Brand, Contact
 * 3. External Links — YouTube, GitHub, Printables with floating animation
 * 4. Highlight — Dynamic project showcase with scrolling animation, pulled from R2 (with interactive stars)
 */
import MainLayout from '../layouts/MainLayout.astro';
import { getR2Data } from '../lib/r2';
import { R2_HIGHLIGHT_BASE } from '../constants';

// ── Fetch highlight data from R2 bucket (dynamic, like the brand page) ──
let highlightTitle = "";
let highlightDescription = "";
let renderUrl = "";

try {
  const highlightProjects = await getR2Data("highlight/");
  for (const project of highlightProjects) {
    const folder = project.folderName === "."
      ? ""
      : `/${encodeURIComponent(project.folderName)}`;
    const base = `${R2_HIGHLIGHT_BASE}${folder}`;
    const files = project.files as string[];

    if (files.includes("title")) {
      try {
        const res = await fetch(`${base}/title`);
        if (res.ok) highlightTitle = (await res.text()).trim();
      } catch { /* title fetch failed, use fallback */ }
    }

    if (files.includes("description")) {
      try {
        const res = await fetch(`${base}/description`);
        if (res.ok) highlightDescription = (await res.text()).trim();
      } catch { /* description fetch failed, use fallback */ }
    }

    // Locate the scrolling animation render file
    const renderExtensions = [".mp4", ".webm", ".mov", ".webp", ".png", ".jpg", ".jpeg", ".gif"];
    const renderFile = files.find((f) =>
      renderExtensions.some((ext) => f.toLowerCase().endsWith(ext))
    );

    if (renderFile) {
      renderUrl = `${base}/${encodeURIComponent(renderFile)}`;
    }
  }
} catch (e) {
  console.error("[Highlight] R2 fetch error:", e);
}

const descriptionLines = highlightDescription
  ? highlightDescription.split("\n").filter(Boolean)
  : [];
const isVideo = !!renderUrl && /\.(mp4|webm|mov)$/i.test(renderUrl);
---

<MainLayout title="Home">
  <section class="hero">
    <h1 class="hero-title">
      <span class="hero-get">Get</span>
      <span class="hero-word-wrap">
        <span class="hero-reel" id="hero-reel">
          <span class="reel-word">files</span>
          <span class="reel-word">data</span>
          <span class="reel-word">assets</span>
          <span class="reel-word">models</span>
          <span class="reel-word">prints</span>
          <span class="reel-word">files</span>
          <span class="reel-word">data</span>
          <span class="reel-word">assets</span>
          <span class="reel-word">models</span>
          <span class="reel-word">prints</span>
          <span class="reel-word">files</span>
          <span class="reel-word">data</span>
          <span class="reel-word">assets</span>
          <span class="reel-word reel-final">info</span>
        </span>
      </span>
    </h1>
    <p class="hero-question">What do you need?</p>
  </section>

  <section class="nav-section scroll-reveal">
    <div class="nav-cards" id="nav-cards">
      <a href="/files" class="nav-pill" data-phase="0">
        <span class="pill-icon">◇</span>
        <span class="pill-label">3D Files</span>
        <span class="pill-arrow">→</span>
      </a>
      <a href="/data" class="nav-pill" data-phase="0.7">
        <span class="pill-icon">◈</span>
        <span class="pill-label">Blaster Data</span>
        <span class="pill-arrow">→</span>
      </a>
      <a href="/brand" class="nav-pill" data-phase="1.4">
        <span class="pill-icon">○</span>
        <span class="pill-label">Brand Assets</span>
        <span class="pill-arrow">→</span>
      </a>
      <a href="/contact" class="nav-pill" data-phase="2.1">
        <span class="pill-icon">◎</span>
        <span class="pill-label">Contact</span>
        <span class="pill-arrow">→</span>
      </a>
    </div>
  </section>

  <section class="links-section scroll-reveal">
    <div class="label-tag" id="explore-tag" data-phase="0.5">External links</div>
    <div class="ext-row" id="ext-row">
      <a href="https://www.youtube.com/@PnguNerf" target="_blank" rel="noopener" class="ext-chip" data-phase="0.3">
        YouTube ↗
      </a>
      <a href="https://github.com/pngu-nerf" target="_blank" rel="noopener" class="ext-chip" data-phase="1.0">
        GitHub ↗
      </a>
      <a href="https://www.printables.com/@PnguNerf_3188348" target="_blank" rel="noopener" class="ext-chip" data-phase="1.7">
        Printables ↗
      </a>
    </div>
  </section>

  <section class="highlight-section" id="highlight-section">
    <svg class="highlight-terrain" viewBox="0 0 1440 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,300 L0,65 C40,55 80,35 130,18 C180,5 220,12 260,28 C290,38 320,22 365,42 C410,68 460,100 520,120 C580,135 640,122 720,128 C800,133 880,142 960,138 C1040,134 1120,142 1200,135 C1260,130 1320,134 1380,138 L1440,135 L1440,300 Z" fill="#b0b0b0"/>
      <path d="M0,65 C40,55 80,35 130,18 C180,5 220,12 260,28 C290,38 320,22 365,42 C410,68 460,100 520,120 C580,135 640,122 720,128 C800,133 880,142 960,138 C1040,134 1120,142 1200,135 C1260,130 1320,134 1380,138 L1440,135" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2.5"/>
    </svg>

    <div class="highlight-star-flood" id="highlight-star-flood" aria-hidden="true"></div>

    <div class="highlight-content">
      <h2 class="highlight-heading scroll-reveal">Highlight</h2>

      <div class="highlight-render-card scroll-reveal" id="highlight-render">
        {isVideo ? (
          <video
            src={renderUrl}
            muted
            playsinline
            preload="auto"
            class="highlight-render-media"
            id="highlight-video"
          />
        ) : renderUrl ? (
          <img
            src={renderUrl}
            alt={highlightTitle || "Project highlight"}
            class="highlight-render-media"
            loading="lazy"
          />
        ) : (
          <div class="highlight-render-placeholder">
            <span>Scrolling Animation</span>
          </div>
        )}
      </div>
    </div>

    <div class="highlight-white-zone">
      <div class="highlight-white-inner">
        <div class="highlight-info scroll-reveal">
          <h2 class="highlight-project-title">
            {highlightTitle || "Project Title"}
          </h2>
          {descriptionLines.length > 0
            ? descriptionLines.map((line) => (
                <p class="highlight-project-desc">{line}</p>
              ))
            : (
              <>
                <p class="highlight-project-desc">Project Description</p>
                <p class="highlight-project-desc">Project Description</p>
                <p class="highlight-project-desc">Project Description</p>
                <p class="highlight-project-desc">Project Description</p>
              </>
            )
          }
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* ── Hero word-wrap mask ── */
  .hero-word-wrap {
    display: inline-block;
    text-align: left;
    position: relative;
    height: 1.1em;
    overflow: visible;
    clip-path: inset(-2% -50vw -2% 0);
    vertical-align: baseline;
    width: 4.5em; /* Default width to fit the longest words */
    transition: width 0.8s cubic-bezier(0.25, 1.2, 0.5, 1);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  /* Applied via JS on the final reel stop to center the shorter word "info" */
  .hero-word-wrap.final-width {
    width: 2.6em; 
  }

  /* ── Highlight Section — dark bg, gray terrain, stars, white bottom ── */
  .highlight-section {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    padding: 0;
    margin-top: 4rem; /* Adjusted margin to accommodate removed scroll block */
  }

  .highlight-terrain {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 72%;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 65%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 0%, black 65%, transparent 100%);
  }

  .highlight-star-flood {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
  }

  .highlight-content {
    position: relative;
    z-index: 2;
    max-width: 980px;
    margin: 0 auto;
    padding: 1rem 2rem 2rem;
  }

  .highlight-heading {
    font-family: var(--font-title);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: 2rem;
    line-height: 1;
  }

  .highlight-render-card {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: var(--accent);
    position: relative;
  }

  .highlight-render-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .highlight-render-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .highlight-render-placeholder span {
    font-family: var(--font-title);
    font-size: clamp(1.5rem, 4vw, 3rem);
    color: rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── White zone at bottom ── */
  .highlight-white-zone {
    position: relative;
    z-index: 2;
    background: #ffffff;
    padding: 2.5rem 0 3rem;
  }

  .highlight-white-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .highlight-info {
    padding: 0;
  }

  .highlight-project-title {
    font-family: var(--font-title);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #111;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  .highlight-project-desc {
    font-family: var(--font-title);
    font-size: clamp(0.85rem, 2vw, 1.15rem);
    font-weight: normal;
    color: var(--accent);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
    line-height: 1.5;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .highlight-heading {
      font-size: 2.5rem;
    }
    .highlight-render-card {
      border-radius: 16px;
    }
    .highlight-project-title {
      font-size: 1.8rem;
    }
  }
</style>

<script is:inline>
  // ============================================
  //  SLOT MACHINE REEL — Vertical word scroll
  // ============================================
  (function() {
    var reel = document.getElementById('hero-reel');
    if (!reel) return;
    var words = reel.querySelectorAll('.reel-word');
    var totalWords = words.length;
    if (totalWords === 0) return;

    var wordH = words[0].offsetHeight;
    var lastIdx = totalWords - 1;

    function getDelay(idx) {
      var t = idx / lastIdx;
      // Sine wave mapping: starts at 0 (fast), curves up to 1 (slow)
      var curve = Math.sin(t * (Math.PI / 2));
      return 20 + curve * 380; // duration maps from 20ms to 400ms per tick
    }

    function scrollToWord(idx) {
      var offset = idx * wordH;
      if (idx < lastIdx) {
        var delay = getDelay(idx);
        // Linear easing ensures a continuous speed sweep without stop-start stuttering
        reel.style.transition = 'transform ' + delay + 'ms linear';
        reel.style.transform = 'translateY(-' + offset + 'px)';
        setTimeout(function() { scrollToWord(idx + 1); }, delay);
      } else {
        // Final word snap with standard easing
        reel.style.transition = 'transform 800ms cubic-bezier(0.25, 1.2, 0.5, 1)';
        reel.style.transform = 'translateY(-' + offset + 'px)';
        
        // Shrink wrapper to perfectly center the final "Get info" text block
        var wrap = document.querySelector('.hero-word-wrap');
        if (wrap) wrap.classList.add('final-width');
      }
    }

    // Delay start slightly
    setTimeout(function() { scrollToWord(1); }, 600);
  })();

  // ============================================
  //  FLOATING SINE WAVE — nav pills & link chips
  // ============================================
  (function() {
    var pills = document.querySelectorAll('#nav-cards .nav-pill');
    var chips = document.querySelectorAll('#ext-row .ext-chip');
    var exploreTag = document.getElementById('explore-tag');
    var all = [].slice.call(pills).concat([].slice.call(chips));
    if (exploreTag) all.push(exploreTag);

    var startTime = performance.now();
    var SETTLE = 6000;
    var MIN_AMP = 0.4;

    function animateFloat(time) {
      var elapsed = time - startTime;
      var decay = Math.max(MIN_AMP / 5, 1 - elapsed / SETTLE);
      var amplitude = 5 * decay;
      
      all.forEach(function(el) {
        var phase = parseFloat(el.dataset.phase || '0');
        var y = Math.sin(time * 0.0015 + phase) * amplitude;
        el.style.transform = 'translateY(' + y.toFixed(2) + 'px)';
      });
      requestAnimationFrame(animateFloat);
    }
    requestAnimationFrame(animateFloat);
  })();

  // ============================================
  //  SCROLL-DRIVEN BACKGROUND COLOR
  // ============================================
  (function() {
    var canvas = document.getElementById('bg-canvas');
    if (!canvas) return;

    function updateScrollColor() {
      var scrollY = window.scrollY;
      var docH = document.documentElement.scrollHeight - window.innerHeight;
      var t = docH > 0 ? scrollY / docH : 0;
      var r, g, b;
      
      if (t < 0.33) {
        var s = t / 0.33;
        r = Math.round(s * 18);
        g = Math.round(s * 17);
        b = Math.round(s * 16);
      } else if (t < 0.66) {
        var s2 = (t - 0.33) / 0.33;
        r = Math.round(18 + s2 * 14);
        g = Math.round(17 - s2 * 12);
        b = Math.round(16 - s2 * 10);
      } else {
        var s3 = (t - 0.66) / 0.34;
        r = Math.round(32 - s3 * 20);
        g = Math.round(5 + s3 * 7);
        b = Math.round(6 - s3 * 2);
      }
      canvas.style.background = 'rgb(' + r + ',' + g + ',' + b + ')';
    }

    window.addEventListener('scroll', updateScrollColor, { passive: true });
    updateScrollColor();
  })();

  // ============================================
  //  INTERACTIVE STAR FLOOD — Highlight Background
  // ============================================
  (function() {
    var container = document.getElementById('highlight-star-flood');
    if (!container) return;

    var canvas = document.createElement('canvas');
    canvas.style.width = '100%';
    canvas.style.height = '100%';
    container.appendChild(canvas);
    var ctx = canvas.getContext('2d');

    var W, H;
    function resize() {
      W = canvas.width = container.clientWidth;
      H = canvas.height = container.clientHeight;
      buildFloodStars();
    }

    var floodStars = [];
    function buildFloodStars() {
      floodStars = [];
      var spacing = 40;
      for (var x = spacing / 2; x < W; x += spacing) {
        for (var y = spacing / 2; y < H; y += spacing) {
          floodStars.push({
            baseX: x, baseY: y,
            size: 0.7 + Math.random() * 0.9,
            twinkle: Math.random() * Math.PI * 2
          });
        }
      }
    }

    resize();
    window.addEventListener('resize', resize);
    
    // Track mouse over the window to ensure it works even if pointer-events: none
    var mouseX = -1000, mouseY = -1000;
    window.addEventListener('mousemove', function(e) {
      var rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    var lastFrame = 0;
    function animate(now) {
      requestAnimationFrame(animate);
      if (now - lastFrame < 33) return;
      lastFrame = now;

      ctx.clearRect(0, 0, W, H);

      var mouseInf = 80;
      var mouseInfSq = mouseInf * mouseInf;
      ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
      ctx.beginPath();
      
      for (var i = 0; i < floodStars.length; i++) {
        var s = floodStars[i];
        var sx = s.baseX;
        var sy = s.baseY;
        
        var mdx = sx - mouseX;
        var mdy = sy - mouseY;
        var mDistSq = mdx * mdx + mdy * mdy;
        
        // Push stars away from cursor
        if (mDistSq < mouseInfSq && mDistSq > 0) {
          var mDist = Math.sqrt(mDistSq);
          var force = (1 - mDist / mouseInf) * 15;
          sx += (mdx / mDist) * force;
          sy += (mdy / mDist) * force;
        }
        
        // Dynamic twinkle pulse
        var alpha = 0.5 + 0.5 * Math.sin(now * 0.002 + s.twinkle);
        ctx.moveTo(sx + s.size, sy);
        ctx.arc(sx, sy, s.size * alpha, 0, Math.PI * 2);
      }
      ctx.fill();
    }

    requestAnimationFrame(animate);
  })();

  // ============================================
  //  SCROLL-DRIVEN VIDEO — highlight render
  // ============================================
  (function() {
    var video = document.getElementById('highlight-video');
    var card = document.getElementById('highlight-render');
    if (!video || !card) return;

    video.pause();

    function syncScroll() {
      var rect = card.getBoundingClientRect();
      var viewH = window.innerHeight;
      var progress = 1 - rect.bottom / (viewH + rect.height);
      progress = Math.max(0, Math.min(1, progress));

      if (video.duration && video.readyState >= 2) {
        video.currentTime = progress * video.duration;
      }
    }

    window.addEventListener('scroll', syncScroll, { passive: true });
    video.addEventListener('loadedmetadata', syncScroll);
  })();
</script>
