---
/**
 * index.astro — PNGU homepage
 *
 * Layout sections (top to bottom):
 * 1. Landing Fold (Sticky 100vh wrapper)
 * a. Hero — "Get ____" slot machine reel
 * b. Nav Cards — Floating pill links
 * c. External Links — YouTube, GitHub, Printables
 * 2. Highlight — Wavy white water that floats up with elastic scroll resistance
 */
import MainLayout from '../layouts/MainLayout.astro';
import { getR2Data } from '../lib/r2';
import { R2_HIGHLIGHT_BASE } from '../constants';

// ── Fetch highlight data from R2 bucket ──
let highlightTitle = "";
let highlightDescription = "";

try {
  const highlightProjects = await getR2Data("highlight/");
  for (const project of highlightProjects) {
    const folder = project.folderName === "." ? "" : `/${encodeURIComponent(project.folderName)}`;
    const base = `${R2_HIGHLIGHT_BASE}${folder}`;
    const files = project.files as string[];

    if (files.includes("title")) {
      try {
        const res = await fetch(`${base}/title`);
        if (res.ok) highlightTitle = (await res.text()).trim();
      } catch { /* fallback */ }
    }
    if (files.includes("description")) {
      try {
        const res = await fetch(`${base}/description`);
        if (res.ok) highlightDescription = (await res.text()).trim();
      } catch { /* fallback */ }
    }
  }
} catch (e) {
  console.error("[Highlight] R2 fetch error:", e);
}

const descriptionLines = highlightDescription
  ? highlightDescription.split("\n").filter(Boolean)
  : [];
---

<MainLayout title="Home">
  
  <div class="landing-fold">
    <section class="hero">
      <h1 class="hero-title">
        <span class="hero-get">Get</span>
        <span class="hero-word-wrap">
          <span class="hero-reel" id="hero-reel">
            <span class="reel-word">files</span>
            <span class="reel-word">data</span>
            <span class="reel-word">cad</span>
            <span class="reel-word">stls</span>
            <span class="reel-word">code</span>
            <span class="reel-word">mods</span>
            <span class="reel-word">parts</span>
            <span class="reel-word">specs</span>
            <span class="reel-word">plans</span>
            <span class="reel-word">ideas</span>
            <span class="reel-word">tools</span>
            <span class="reel-word">props</span>
            <span class="reel-word">assets</span>
            <span class="reel-word">models</span>
            <span class="reel-word">prints</span>
            <span class="reel-word">guides</span>
            <span class="reel-word">stuff</span>
            <span class="reel-word reel-final">info</span>
          </span>
        </span>
      </h1>
      <p class="hero-question">What do you need?</p>
    </section>

    <section class="nav-section scroll-reveal">
      <div class="nav-cards" id="nav-cards">
        <a href="/files" class="nav-pill" data-phase="0">
          <span class="pill-icon">◇</span>
          <span class="pill-label">3D Files</span>
          <span class="pill-arrow">→</span>
        </a>
        <a href="/data" class="nav-pill" data-phase="0.7">
          <span class="pill-icon">◈</span>
          <span class="pill-label">Blaster Data</span>
          <span class="pill-arrow">→</span>
        </a>
        <a href="/brand" class="nav-pill" data-phase="1.4">
          <span class="pill-icon">○</span>
          <span class="pill-label">Brand Assets</span>
          <span class="pill-arrow">→</span>
        </a>
        <a href="/contact" class="nav-pill" data-phase="2.1">
          <span class="pill-icon">◎</span>
          <span class="pill-label">Contact</span>
          <span class="pill-arrow">→</span>
        </a>
      </div>
    </section>

    <section class="links-section scroll-reveal">
      <div class="label-tag" id="explore-tag" data-phase="0.5">External links</div>
      <div class="ext-row" id="ext-row">
        <a href="https://www.youtube.com/@PnguNerf" target="_blank" rel="noopener" class="ext-chip" data-phase="0.3">
          YouTube ↗
        </a>
        <a href="https://github.com/pngu-nerf" target="_blank" rel="noopener" class="ext-chip" data-phase="1.0">
          GitHub ↗
        </a>
        <a href="https://www.printables.com/@PnguNerf_3188348" target="_blank" rel="noopener" class="ext-chip" data-phase="1.7">
          Printables ↗
        </a>
      </div>
    </section>
  </div>

  <section class="highlight-section" id="highlight-section">
    <svg class="highlight-terrain" viewBox="0 0 1440 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,300 L0,65 C40,55 80,35 130,18 C180,5 220,12 260,28 C290,38 320,22 365,42 C410,68 460,100 520,120 C580,135 640,122 720,128 C800,133 880,142 960,138 C1040,134 1120,142 1200,135 C1260,130 1320,134 1380,138 L1440,135 L1440,300 Z" fill="#ffffff"/>
      <path d="M0,65 C40,55 80,35 130,18 C180,5 220,12 260,28 C290,38 320,22 365,42 C410,68 460,100 520,120 C580,135 640,122 720,128 C800,133 880,142 960,138 C1040,134 1120,142 1200,135 C1260,130 1320,134 1380,138 L1440,135" fill="none" stroke="rgba(0,0,0,0.05)" stroke-width="2.5"/>
    </svg>

    <div class="highlight-star-flood" id="highlight-star-flood" aria-hidden="true"></div>

    <div class="highlight-content">
      <h2 class="highlight-heading scroll-reveal">Highlight</h2>

      <div class="highlight-render-card cinematic-box scroll-reveal" id="highlight-render">
        <img
          id="cinematic-sequence"
          src=""
          alt="Cinematic Scroll Animation"
          class="highlight-render-media"
        />
        <div class="highlight-render-placeholder" id="cinematic-placeholder">
          <span>60-Frame Sequence Loading</span>
        </div>
      </div>
    </div>

    <div class="highlight-white-zone">
      <div class="highlight-white-inner">
        <div class="highlight-info scroll-reveal">
          <h2 class="highlight-project-title">
            {highlightTitle || "Project Title"}
          </h2>
          {descriptionLines.length > 0
            ? descriptionLines.map((line) => (
                <p class="highlight-project-desc">{line}</p>
              ))
            : (
              <>
                <p class="highlight-project-desc">Project Description</p>
                <p class="highlight-project-desc">Project Description</p>
                <p class="highlight-project-desc">Project Description</p>
                <p class="highlight-project-desc">Project Description</p>
              </>
            )
          }
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* ── Landing Fold Wrapper (Sticky Parallax Effect) ── */
  .landing-fold {
    height: 100vh;
    position: sticky;
    top: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero {
    padding: 0 0 3rem; 
    text-align: center;
  }

  .hero-word-wrap {
    display: inline-block;
    text-align: left;
    position: relative;
    height: 1.1em;
    overflow: visible;
    clip-path: inset(-2% -50vw -2% 0);
    vertical-align: baseline;
    width: 2.7em; 
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  /* ── Highlight Section (The White Flood Water) ── */
  .highlight-section {
    position: relative;
    z-index: 10;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    /* Protrudes upward into the bottom of the viewport on initial load */
    margin-top: -15vh; 
    padding: 0;
    padding-bottom: 25vh; /* Provides runway for the gradient to transition back to the strands */
    
    /* White body fading transparent at the bottom to reveal footer/aurora */
    background: linear-gradient(to bottom, #ffffff 0%, #ffffff 75%, transparent 100%);
    
    /* Prepares the element for the JS elastic scroll transform */
    will-change: transform;
  }

  /* Wavy white rim of the water */
  .highlight-terrain {
    position: absolute;
    bottom: 99.5%; 
    left: -10vw;
    width: 120vw;
    height: 160px;
    z-index: 0;
    transform-origin: bottom center;
    /* Exaggerated breathing animation */
    animation: terrainBreathe 6s ease-in-out infinite alternate;
    pointer-events: none;
  }

  @keyframes terrainBreathe {
    0% { transform: translateY(0px) scale(1) rotate(-0.5deg); }
    100% { transform: translateY(16px) scale(1.04) rotate(1.2deg); }
  }

  .highlight-star-flood {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
  }

  .highlight-content {
    position: relative;
    z-index: 2;
    max-width: none; /* Removed limits to allow cinematic full-bleed */
    margin: 0 auto;
    padding: 1rem 0 2rem;
  }

  .highlight-heading {
    font-family: var(--font-title);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000000; /* Black text for white background */
    margin-bottom: 2rem;
    line-height: 1;
    text-align: center;
  }

  /* ── Cinematic 21:9 Full-Bleed Render Box ── */
  .highlight-render-card.cinematic-box {
    width: 100vw;
    aspect-ratio: 21 / 9;
    border-radius: 0; /* Full bleed edge-to-edge */
    overflow: hidden;
    background: #e0e0e0;
    position: relative;
  }

  .highlight-render-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
  }

  .highlight-render-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .highlight-render-placeholder span {
    font-family: var(--font-title);
    font-size: clamp(1.5rem, 4vw, 3rem);
    color: rgba(0, 0, 0, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── White zone info at bottom ── */
  .highlight-white-zone {
    position: relative;
    z-index: 2;
    background: transparent;
    padding: 2.5rem 0 3rem;
  }

  .highlight-white-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .highlight-info {
    padding: 0;
  }

  .highlight-project-title {
    font-family: var(--font-title);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000000; /* Black text */
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  .highlight-project-desc {
    font-family: var(--font-title);
    font-size: clamp(0.85rem, 2vw, 1.15rem);
    font-weight: normal;
    color: #444444; /* Dark grey for readability */
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
    line-height: 1.5;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .highlight-heading { font-size: 2.5rem; }
    .highlight-project-title { font-size: 1.8rem; }
  }
</style>

<script is:inline>
  // ============================================
  //  ELASTIC SINE WAVE SCROLL (The "Water Flood" effect)
  // ============================================
  (function() {
    var highlight = document.getElementById('highlight-section');
    if (!highlight) return;

    window.addEventListener('scroll', function() {
      var y = window.scrollY;
      var vh = window.innerHeight;
      
      // Calculate progress over the first 1.5 screen heights of scrolling
      var p = Math.max(0, Math.min(1, y / (vh * 1.5)));
      
      // Full sine wave mapping: 0 -> 1 -> 0 -> -1 -> 0
      // This forces the section to:
      // 1. Push down (Resist)
      // 2. Snap back to 0 (Speed up)
      // 3. Push up (Overshoot/Speed up more)
      // 4. Settle back to 0 (Slow down)
      var offset = Math.sin(p * Math.PI * 2) * 120; 
      
      highlight.style.transform = 'translateY(' + offset + 'px)';
    }, { passive: true });
  })();

  // ============================================
  //  CINEMATIC 60-FRAME SCROLLER (Lowest Debt)
  // ============================================
  (function() {
    var img = document.getElementById('cinematic-sequence');
    var card = document.getElementById('highlight-render');
    var placeholder = document.getElementById('cinematic-placeholder');
    if (!img || !card) return;

    var totalFrames = 60;
    
    // 👇 YOUR ANIMATION PATH HERE 👇
    // Place your files in the public folder and return the path structure here.
    function getFrameUrl(frameNum) {
      // Example: If your files are public/animation/frame_1.jpg ...
      return `/animation/frame_${frameNum}.jpg`; 
    }

    // Preload the first few frames so it doesn't flash empty when scrolling starts
    var preloaded = [];
    for(var i = 1; i <= 15; i++) {
      var pre = new Image();
      pre.src = getFrameUrl(i);
      preloaded.push(pre);
    }
    
    // Set initial frame
    img.src = getFrameUrl(1);

    // Hide placeholder once first image loads
    img.onload = function() {
      if (placeholder) placeholder.style.display = 'none';
    };

    function syncScroll() {
      var rect = card.getBoundingClientRect();
      var viewH = window.innerHeight;
      
      // Calculate scroll progress exclusively while the box is visible on screen
      var progress = 1 - rect.bottom / (viewH + rect.height);
      progress = Math.max(0, Math.min(1, progress));

      // Map progress to 1-60
      var frame = Math.max(1, Math.min(totalFrames, Math.ceil(progress * totalFrames)));
      
      img.src = getFrameUrl(frame);
    }

    window.addEventListener('scroll', syncScroll, { passive: true });
    // Initial sync
    syncScroll();
  })();

  // ============================================
  //  SLOT MACHINE REEL
  // ============================================
  (function() {
    var reel = document.getElementById('hero-reel');
    if (!reel) return;
    var words = reel.querySelectorAll('.reel-word');
    var totalWords = words.length;
    if (totalWords === 0) return;

    var wordH = words[0].offsetHeight;
    var lastIdx = totalWords - 1;

    function getDelay(idx) {
      var t = idx / lastIdx;
      var curve = Math.sin(t * (Math.PI / 2));
      // Halved durations to match the longer list speed requirement
      return 10 + curve * 180; 
    }

    function scrollToWord(idx) {
      var offset = idx * wordH;
      if (idx < lastIdx) {
        var delay = getDelay(idx);
        reel.style.transition = 'transform ' + delay + 'ms linear';
        reel.style.transform = 'translateY(-' + offset + 'px)';
        setTimeout(function() { scrollToWord(idx + 1); }, delay);
      } else {
        reel.style.transition = 'transform 600ms cubic-bezier(0.25, 1.2, 0.5, 1)';
        reel.style.transform = 'translateY(-' + offset + 'px)';
      }
    }

    setTimeout(function() { scrollToWord(1); }, 400);
  })();

  // ============================================
  //  FLOATING SINE WAVE — nav pills
  // ============================================
  (function() {
    var pills = document.querySelectorAll('#nav-cards .nav-pill');
    var chips = document.querySelectorAll('#ext-row .ext-chip');
    var exploreTag = document.getElementById('explore-tag');
    var all = [].slice.call(pills).concat([].slice.call(chips));
    if (exploreTag) all.push(exploreTag);

    var startTime = performance.now();
    var SETTLE = 6000;
    var MIN_AMP = 0.4;

    function animateFloat(time) {
      var elapsed = time - startTime;
      var decay = Math.max(MIN_AMP / 5, 1 - elapsed / SETTLE);
      var amplitude = 5 * decay;
      
      all.forEach(function(el) {
        var phase = parseFloat(el.dataset.phase || '0');
        var y = Math.sin(time * 0.0015 + phase) * amplitude;
        el.style.transform = 'translateY(' + y.toFixed(2) + 'px)';
      });
      requestAnimationFrame(animateFloat);
    }
    requestAnimationFrame(animateFloat);
  })();

  // ============================================
  //  INTERACTIVE STAR FLOOD (Dark Stars on White)
  // ============================================
  (function() {
    var container = document.getElementById('highlight-star-flood');
    if (!container) return;

    var canvas = document.createElement('canvas');
    canvas.style.width = '100%';
    canvas.style.height = '100%';
    container.appendChild(canvas);
    var ctx = canvas.getContext('2d');

    var W, H;
    function resize() {
      W = canvas.width = container.clientWidth;
      H = canvas.height = container.clientHeight;
      buildFloodStars();
    }

    var floodStars = [];
    function buildFloodStars() {
      floodStars = [];
      var spacing = 40;
      for (var x = spacing / 2; x < W; x += spacing) {
        for (var y = spacing / 2; y < H; y += spacing) {
          floodStars.push({
            baseX: x, baseY: y,
            // Stars made significantly larger per instruction
            size: 2.0 + Math.random() * 2.5,
            twinkle: Math.random() * Math.PI * 2
          });
        }
      }
    }

    resize();
    window.addEventListener('resize', resize);
    
    var mouseX = -1000, mouseY = -1000;
    window.addEventListener('mousemove', function(e) {
      var rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    var lastFrame = 0;
    function animate(now) {
      requestAnimationFrame(animate);
      if (now - lastFrame < 33) return;
      lastFrame = now;

      ctx.clearRect(0, 0, W, H);

      var mouseInf = 80;
      var mouseInfSq = mouseInf * mouseInf;
      // Dark grey color to contrast against the white background
      ctx.fillStyle = 'rgba(0, 0, 0, 0.15)';
      ctx.beginPath();
      
      for (var i = 0; i < floodStars.length; i++) {
        var s = floodStars[i];
        var sx = s.baseX;
        var sy = s.baseY;
        
        var mdx = sx - mouseX;
        var mdy = sy - mouseY;
        var mDistSq = mdx * mdx + mdy * mdy;
        
        if (mDistSq < mouseInfSq && mDistSq > 0) {
          var mDist = Math.sqrt(mDistSq);
          var force = (1 - mDist / mouseInf) * 15;
          sx += (mdx / mDist) * force;
          sy += (mdy / mDist) * force;
        }
        
        var alpha = 0.5 + 0.5 * Math.sin(now * 0.002 + s.twinkle);
        ctx.moveTo(sx + s.size, sy);
        ctx.arc(sx, sy, s.size * alpha, 0, Math.PI * 2);
      }
      ctx.fill();
    }

    requestAnimationFrame(animate);
  })();
</script>
