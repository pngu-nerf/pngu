---
/**
 * Home page — flat directory of sections, no animations, no hero theatrics.
 * Built for skim-and-click: header, four section links, external links, done.
 */
import MainLayout from '../layouts/MainLayout.astro';

const SECTIONS = [
  { href: '/files',   name: 'Files',   desc: '3D models and STLs' },
  { href: '/data',    name: 'Data',    desc: 'Blaster specs and documentation' },
  { href: '/brand',   name: 'Brand',   desc: 'Logos and brand assets' },
  { href: '/contact', name: 'Contact', desc: 'Email and Discord' },
];

const EXTERNAL = [
  { href: 'https://www.youtube.com/@PnguNerf',            label: 'YouTube' },
  { href: 'https://github.com/pngu-nerf',                 label: 'GitHub' },
  { href: 'https://www.printables.com/@PnguNerf_3188348', label: 'Printables' },
];
---

<MainLayout title="Home">
  <div class="page-header">
    <div class="label-tag">pngu.info</div>
    <h1>Open-Source Blaster Resources</h1>
    <p class="header-subtitle">
      Files, data, and assets for the Nerf modding community.
    </p>
  </div>

  <nav class="sections" aria-label="Site sections">
    {SECTIONS.map((s) => (
      <a href={s.href} class="section-row">
        <span class="section-name">{s.name}</span>
        <span class="section-desc">{s.desc}</span>
        <span class="section-arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </nav>

  <div class="external">
    <span class="external-label">External</span>
    <ul class="external-list">
      {EXTERNAL.map((l) => (
        <li>
          <a href={l.href} target="_blank" rel="noopener">{l.label} ↗</a>
        </li>
      ))}
    </ul>
  </div>
</MainLayout>

<style>
  /* ============================================================
     Section list — flat rows, underline-on-hover, no transforms
     ============================================================ */
  .sections {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--glass-border);
    margin: 2rem 0;
  }
  .section-row {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1rem 0.25rem;
    border-bottom: 1px solid var(--glass-border);
    text-decoration: none;
    color: var(--text-primary);
    transition: background var(--transition-fast),
      color var(--transition-fast);
  }
  @media (hover: hover) {
    .section-row:hover {
      background: var(--glass-bg);
      color: var(--accent);
    }
    .section-row:hover .section-arrow { color: var(--accent); }
  }
  .section-name {
    font-family: var(--font-title);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .section-arrow {
    color: var(--text-muted);
    font-size: 1.1rem;
    transition: color var(--transition-fast);
  }

  /* ============================================================
     External links — single inline row, plain text
     ============================================================ */
  .external {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    font-size: 0.9rem;
  }
  .external-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }
  .external-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .external-list a {
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast),
      border-color var(--transition-fast);
  }
  .external-list a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 640px) {
    .section-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      row-gap: 0.25rem;
    }
    .section-name { grid-column: 1; grid-row: 1; }
    .section-desc { grid-column: 1; grid-row: 2; }
    .section-arrow { grid-column: 2; grid-row: 1 / span 2; align-self: center; }
  }
</style>
