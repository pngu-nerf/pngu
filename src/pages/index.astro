</MainLayout>

<style>
  /* ── Variables & Layout ── */
  :root {
    /* 50vw doubles the size from the previous version */
    --portal-w: 50vw; 
  }
  @media (max-width: 768px) {
    :root {
      --portal-w: 85vw;
    }
  }

  .zoom-scene {
    height: 450vh; 
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    position: relative;
    z-index: 1; 
  }

  .sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden; 
  }

  /* ── LAYER 3: HERO ── */
  .layer-hero {
    position: absolute; inset: 0; z-index: 3;
    display: flex; flex-direction: column; justify-content: center;
    opacity: var(--hero-opacity, 1);
    transform: scale(var(--hero-scale, 1));
    pointer-events: var(--hero-events, auto);
  }

  .landing-fold { height: 100vh; display: flex; flex-direction: column; justify-content: center; margin-top: -2rem; }
  .hero { padding: 0 0 3rem; text-align: center; }
  .hero-word-wrap { display: inline-block; text-align: left; position: relative; height: 1.1em; overflow: visible; clip-path: inset(-2% -50vw -2% 0); vertical-align: baseline; width: 2.7em; -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); }

  .nav-section { width: 100%; display: flex; flex-direction: column; align-items: center; }
  .mobile-nav-toggle {
    display: none; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 50%; width: 48px; height: 48px; cursor: pointer; flex-direction: column; justify-content: center; align-items: center; gap: 6px; transition: background 0.3s ease; margin-bottom: 1rem;
  }
  .mobile-nav-toggle span { display: block; width: 20px; height: 2px; background: #fff; transition: 0.3s; }
  .mobile-nav-toggle.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .mobile-nav-toggle.open span:nth-child(2) { opacity: 0; }
  .mobile-nav-toggle.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  .nav-cards { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; width: 100%; max-width: clamp(320px, 50vw, 980px); margin: 0 auto; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }

  @media (max-width: 768px) {
    .mobile-nav-toggle { display: flex; }
    .nav-cards { flex-direction: column; align-items: center; max-height: 0; opacity: 0; overflow: hidden; transform: translateY(-10px); }
    .nav-cards.open { max-height: 400px; opacity: 1; transform: translateY(0); overflow: visible; }
    .nav-cards .nav-pill { width: 100%; max-width: 280px; justify-content: space-between; }
  }

  /* ── LAYER 2: THE PORTAL ── */
  .layer-portal {
    position: absolute;
    /* SHIFTED EXACTLY 50PX UP as requested */
    top: calc(50% - 50px); 
    left: 50%;
    width: var(--portal-w); 
    aspect-ratio: 2.1605; /* Exact math bounds of the SVG logo */
    z-index: 2;
    transform-origin: center center;
    /* Scales up natively, GPU accelerated */
    transform: translate(-50%, -50%) scale(var(--portal-scale, 1));
    will-change: transform, opacity;
    pointer-events: none;
  }

  /* FROST: ONLY exists inside the penguin shape */
  .portal-frost {
    position: absolute; inset: 0;
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    background: rgba(255, 255, 255, 0.05);
    -webkit-mask-size: 100% 100%;
    -webkit-mask-position: center center;
    -webkit-mask-repeat: no-repeat;
    opacity: var(--frost-opacity, 1);
  }

  /* TRACES: Drawn natively over the hole, letting the glow bleed outwards */
  .portal-svg {
    position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible;
    opacity: var(--traces-opacity, 1);
  }

  /* NO VECTOR-EFFECT! This physically swells the strokes as it flies past the camera */
  .css-trace { fill: none; stroke-width: 4px; stroke-linecap: round; }
  
  .trace-1 { stroke: rgba(193, 17, 17, 0.9); stroke-dasharray: 200 1500; animation: traceMove 6s linear infinite; }
  .trace-2 { stroke: rgba(220, 60, 60, 0.8); stroke-dasharray: 100 1600; animation: traceMove 4s linear infinite reverse; animation-delay: -2s; }
  .trace-3 { stroke: rgba(255, 255, 255, 0.5); stroke-dasharray: 50 1650; animation: traceMove 5s linear infinite; animation-delay: -1s; }
  @keyframes traceMove { from { stroke-dashoffset: 1700; } to { stroke-dashoffset: 0; } }

  .portal-glow-aura {
    position: absolute; inset: 0; width: 100%; height: 100%;
    background: radial-gradient(circle, rgba(193,17,17,0.15) 0%, rgba(193,17,17,0) 65%);
    animation: pulseGlow 4s ease-in-out infinite alternate;
  }
  @keyframes pulseGlow { 0% { transform: scale(0.9); opacity: 0.6; } 100% { transform: scale(1.1); opacity: 1; } }

  /* ── LAYER 1: HIGHLIGHT (Behind everything) ── */
  .layer-highlight {
    position: absolute; inset: 0; z-index: 1;
    /* Stays totally invisible until the portal is big enough to cover the screen */
    opacity: var(--highlight-opacity, 0); 
  }

  .highlight-wrapper {
    position: absolute; inset: 0; background: #ffffff; display: flex; flex-direction: column; justify-content: center; align-items: center;
  }

  .highlight-content {
    position: relative; z-index: 2; width: 100vw; margin: 0; padding: 2rem 0; display: flex; flex-direction: column; align-items: center;
  }
  .highlight-heading { font-family: var(--font-title); font-size: clamp(3.5rem, 8vw, 6rem); font-weight: normal; letter-spacing: 0.02em; text-transform: uppercase; color: #000000; margin-bottom: 2rem; line-height: 1; text-align: center; }

  /* Cinematic Box */
  .highlight-render-card.cinematic-box {
    --shrink: var(--shrinkP, 0);
    /* 100vw (Full Bleed) when shrink=0, shrinks to exactly leave margins when shrink=1 */
    width: calc(100vw - (var(--shrink) * max(8vw, 100vw - 1200px)));
    min-height: calc(100vh - (var(--shrink) * 100vh));
    border-radius: calc(var(--shrink) * 24px);
    aspect-ratio: 21 / 9; 
    
    background: #e0e0e0; position: relative; overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15); 
    margin: 0 auto;
    will-change: width, border-radius;
  }
  
  .highlight-render-media { width: 100%; height: 100%; object-fit: cover; display: block; position: absolute; top: 0; left: 0; z-index: 2; }
  .highlight-render-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: absolute; top: 0; left: 0; z-index: 1; }
  .highlight-render-placeholder span { font-family: var(--font-title); font-size: clamp(1.5rem, 4vw, 3rem); color: rgba(0, 0, 0, 0.3); text-transform: uppercase; letter-spacing: 0.04em; }

  .highlight-star-flood { position: absolute; inset: 0; z-index: 1; pointer-events: none; -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%); mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%); }

  /* ── Bottom White Zone ── */
  .highlight-white-zone { position: relative; z-index: 10; background: #ffffff; padding: 0 0 3rem; }
  .highlight-white-inner { max-width: 1200px; width: 92vw; margin: 0 auto; padding: 0; }
  .highlight-info { padding: 0; }
  .highlight-project-title { font-family: var(--font-title); font-size: clamp(2rem, 5vw, 3.5rem); color: #000000; text-transform: uppercase; margin-bottom: 0.5rem; line-height: 1.1; }
  .highlight-project-desc { font-family: var(--font-title); font-size: clamp(0.85rem, 2vw, 1.15rem); color: #444444; text-transform: uppercase; margin-bottom: 0.2rem; line-height: 1.5; }
  .highlight-fade-out { position: relative; z-index: 10; height: 30vh; background: linear-gradient(to bottom, #ffffff 0%, transparent 100%); }

  @media (max-width: 640px) {
    .highlight-heading { font-size: 2.5rem; }
    .highlight-project-title { font-size: 1.8rem; }
  }
</style>

<script is:inline>
  // ============================================
  //  MOBILE MENU TOGGLE
  // ============================================
  (function() {
    var toggle = document.getElementById('mobile-nav-toggle');
    var navCards = document.getElementById('nav-cards');
    if (toggle && navCards) {
      toggle.addEventListener('click', function() {
        toggle.classList.toggle('open');
        navCards.classList.toggle('open');
      });
    }
  })();

  // ============================================
  //  SINE-WAVE ACCELERATED PARALLAX ENGINE
  // ============================================
  (function() {
    var img = document.getElementById('cinematic-sequence');
    var placeholder = document.getElementById('cinematic-placeholder');
    var totalFrames = 60;

    function getFrameUrl(frameNum) { return `/animation/frame_${frameNum}.jpg`; }

    // Preload sequence
    for(var i = 1; i <= 15; i++) { var pre = new Image(); pre.src = getFrameUrl(i); }
    if (img) {
      img.src = getFrameUrl(1);
      img.onload = function() { if(placeholder) placeholder.style.display = 'none'; };
    }

    window.addEventListener('scroll', function() {
      var vh = window.innerHeight;
      var scene = document.getElementById('zoom-scene');
      if (!scene) return;
      
      var rect = scene.getBoundingClientRect();
      var scrollY = Math.max(0, -rect.top);
      var root = document.documentElement;
      
      // PHASE 1: Sine-Wave Zoom (0 -> 150vh)
      var zoomEnd = vh * 1.5;
      var zoomP = Math.max(0, Math.min(1, scrollY / zoomEnd));
      
      // SINE WAVE EASE: Starts slow, massively accelerates, then smooths out
      var easeZoomP = -(Math.cos(Math.PI * zoomP) - 1) / 2;
      
      // Scale portal aggressively up to 80x size (forces screen pass-through)
      var scale = Math.pow(80, easeZoomP);
      root.style.setProperty('--portal-scale', scale);
      
      // Hero layer fades out quickly in first 40%
      var heroP = Math.max(0, Math.min(1, easeZoomP / 0.4));
      root.style.setProperty('--hero-opacity', 1 - heroP);
      root.style.setProperty('--hero-scale', 1 + (heroP * 0.15));
      root.style.setProperty('--hero-events', heroP > 0.5 ? 'none' : 'auto');

      // The Portal Frost fades away ("defrosts") as it gets large
      var frostP = Math.max(0, Math.min(1, (easeZoomP - 0.6) / 0.3));
      root.style.setProperty('--frost-opacity', 1 - frostP);

      // Traces fade out completely right before screen edge to prevent blindness
      var tracesP = Math.max(0, Math.min(1, (easeZoomP - 0.5) / 0.3));
      root.style.setProperty('--traces-opacity', 1 - tracesP);

      // Highlight Video fades in exactly as the frost disappears
      var highFadeP = Math.max(0, Math.min(1, (easeZoomP - 0.6) / 0.3));
      root.style.setProperty('--highlight-opacity', highFadeP);


      // PHASE 2: Cinematic Scrub & Shrink (150vh -> 350vh)
      var scrubStart = vh * 1.5;
      var scrubDuration = vh * 2.0;
      var scrubP = Math.max(0, Math.min(1, (scrollY - scrubStart) / scrubDuration));
      
      // Box stays Full-Bleed, then shrinks in the final 30% of scroll
      var shrinkP = Math.max(0, Math.min(1, (scrubP - 0.7) / 0.3));
      root.style.setProperty('--shrinkP', shrinkP * shrinkP); 
      
      // Video Frame Mapping
      if (img) {
        var frameProgress = Math.min(1, scrubP / 0.7);
        var frame = Math.max(1, Math.min(totalFrames, Math.ceil(frameProgress * totalFrames)));
        var targetSrc = getFrameUrl(frame);
        if (img.getAttribute('src') !== targetSrc) img.setAttribute('src', targetSrc);
      }
    }, { passive: true });
  })();

  // ============================================
  //  SLOT MACHINE REEL
  // ============================================
  (function() {
    var reel = document.getElementById('hero-reel');
    if (!reel) return;
    var words = reel.querySelectorAll('.reel-word');
    var totalWords = words.length;
    var wordH = words[0].offsetHeight;
    var lastIdx = totalWords - 1;

    function scrollToWord(idx) {
      var offset = idx * wordH;
      if (idx < lastIdx) {
        var delay = 10 + Math.sin((idx / lastIdx) * (Math.PI / 2)) * 180;
        reel.style.transition = 'transform ' + delay + 'ms linear';
        reel.style.transform = 'translateY(-' + offset + 'px)';
        setTimeout(function() { scrollToWord(idx + 1); }, delay);
      } else {
        reel.style.transition = 'transform 600ms cubic-bezier(0.25, 1.2, 0.5, 1)';
        reel.style.transform = 'translateY(-' + offset + 'px)';
      }
    }
    setTimeout(function() { scrollToWord(1); }, 400);
  })();

  // ============================================
  //  FLOATING SINE WAVE — nav pills
  // ============================================
  (function() {
    var all = [].slice.call(document.querySelectorAll('#nav-cards .nav-pill'))
                .concat([].slice.call(document.querySelectorAll('#ext-row .ext-chip')));
    var exploreTag = document.getElementById('explore-tag');
    if (exploreTag) all.push(exploreTag);

    var startTime = performance.now();
    function animateFloat(time) {
      var decay = Math.max(0.08, 1 - (time - startTime) / 6000);
      all.forEach(function(el) {
        var y = Math.sin(time * 0.0015 + parseFloat(el.dataset.phase || '0')) * (5 * decay);
        el.style.transform = 'translateY(' + y.toFixed(2) + 'px)';
      });
      requestAnimationFrame(animateFloat);
    }
    requestAnimationFrame(animateFloat);
  })();

  // ============================================
  //  INTERACTIVE STAR FLOOD (Dark Stars on White)
  // ============================================
  (function() {
    var container = document.getElementById('highlight-star-flood');
    if (!container) return;
    var canvas = document.createElement('canvas');
    canvas.style.width = '100%'; canvas.style.height = '100%';
    container.appendChild(canvas);
    var ctx = canvas.getContext('2d'), W, H, floodStars = [], mouseX = -1000, mouseY = -1000;

    function resize() {
      W = canvas.width = container.clientWidth; H = canvas.height = container.clientHeight;
      floodStars = [];
      for (var x = 20; x < W; x += 40) {
        for (var y = 20; y < H; y += 40) {
          floodStars.push({ baseX: x, baseY: y, size: 2.0 + Math.random() * 2.5, twinkle: Math.random() * Math.PI * 2 });
        }
      }
    }
    resize(); window.addEventListener('resize', resize);
    window.addEventListener('mousemove', function(e) {
      var rect = canvas.getBoundingClientRect(); mouseX = e.clientX - rect.left; mouseY = e.clientY - rect.top;
    });

    function animate(now) {
      requestAnimationFrame(animate);
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = 'rgba(0, 0, 0, 0.15)'; ctx.beginPath();
      
      for (var i = 0; i < floodStars.length; i++) {
        var s = floodStars[i], sx = s.baseX, sy = s.baseY, mdx = sx - mouseX, mdy = sy - mouseY, mDistSq = mdx * mdx + mdy * mdy;
        if (mDistSq < 6400 && mDistSq > 0) {
          var mDist = Math.sqrt(mDistSq), force = (1 - mDist / 80) * 15;
          sx += (mdx / mDist) * force; sy += (mdy / mDist) * force;
        }
        var alpha = 0.5 + 0.5 * Math.sin(now * 0.002 + s.twinkle);
        ctx.moveTo(sx + s.size, sy); ctx.arc(sx, sy, s.size * alpha, 0, Math.PI * 2);
      }
      ctx.fill();
    }
    requestAnimationFrame(animate);
  })();
</script>
