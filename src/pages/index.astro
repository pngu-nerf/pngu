<style>
  /* ── 3D Scene Architecture ── */
  .zoom-scene {
    height: 450vh; 
    position: relative;
    z-index: 10;
  }

  .sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    perspective: 1000px; 
    z-index: 1;
  }

  .world {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    will-change: transform;
    pointer-events: none; 
  }

  /* ── Front Layer: Hero ── */
  .layer-hero {
    position: absolute;
    inset: 0;
    width: 100vw;
    height: 100vh;
    transform: translateZ(0px);
    pointer-events: auto; 
    will-change: opacity;
  }

  .landing-fold {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-top: -2rem;
  }

  .hero { padding: 0 0 3rem; text-align: center; }
  .hero-word-wrap {
    display: inline-block;
    text-align: left;
    position: relative;
    height: 1.1em;
    overflow: visible;
    clip-path: inset(-2% -50vw -2% 0);
    vertical-align: baseline;
    width: 2.7em; 
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  /* ── Middle Layer: The Penguin Portal ── */
  /* Because Z=-1000px cuts visual scale in half, we make this layer exactly 200vw x 200vh.
     This counteracts the perspective scaling perfectly so the mask and canvas bounds precisely 
     match the physical screen, locking the hole punch to the glowing traces.
  */
  .layer-window {
    position: absolute;
    width: 200vw;
    height: 200vh;
    left: -50vw;
    top: -50vh;
    transform: translateZ(-1000px);
    pointer-events: none;
    will-change: opacity;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .glass-wall {
    position: absolute;
    inset: 0;
    background: rgba(8, 8, 10, 0.85);
    backdrop-filter: blur(15px);
    
    /* 40vw is relative to the viewport, ensuring the mask sizes correctly on any screen */
    -webkit-mask-image: url('/brand-assets/PNGU-logo-white.svg'), linear-gradient(#fff, #fff);
    -webkit-mask-size: 40vw auto, 100% 100%;
    -webkit-mask-position: center center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-composite: source-out;
    mask-composite: exclude;
  }

  /* Embedded Canvas for Traces & Glow */
  #portal-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  /* ── Back Layer: Highlight (The bright void inside the portal) ── */
  .layer-highlight {
    position: absolute;
    width: 100vw;
    height: 100vh;
    top: 0;
    left: 0;
    transform: translateZ(-2000px);
    background: #ffffff;
    /* Box shadow ensures we never see the "edges" of the room while zooming towards it */
    box-shadow: 0 0 0 200vw #ffffff; 
    display: flex;
    flex-direction: column;
    justify-content: center;
    pointer-events: auto;
    opacity: 0; 
    will-change: opacity;
  }

  .highlight-content {
    position: relative;
    z-index: 2;
    width: 100vw;
    margin: 0;
    padding: 2rem 0;
  }

  .highlight-heading {
    font-family: var(--font-title);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000000; 
    margin-bottom: 2rem;
    line-height: 1;
    text-align: center;
  }

  .highlight-render-card.cinematic-box {
    width: 100vw;
    aspect-ratio: 21 / 9;
    border-radius: 0; 
    background: #e0e0e0;
    position: relative;
    overflow: hidden;
  }

  .highlight-render-media {
    width: 100%; height: 100%; object-fit: cover; display: block; position: absolute; top: 0; left: 0; z-index: 2;
  }
  .highlight-render-placeholder {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: absolute; top: 0; left: 0; z-index: 1;
  }
  .highlight-render-placeholder span {
    font-family: var(--font-title); font-size: clamp(1.5rem, 4vw, 3rem); color: rgba(0, 0, 0, 0.3); text-transform: uppercase; letter-spacing: 0.04em;
  }

  .highlight-star-flood {
    position: absolute; 
    inset: -50vw; /* Extends past boundaries slightly to cover overscan */
    z-index: 1; 
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 5%, black 62%, transparent 80%);
  }

  /* ── Bottom White Zone & Fade Out ── */
  .highlight-white-zone {
    position: relative; z-index: 10; background: #ffffff; padding: 1rem 0 3rem;
  }
  .highlight-white-inner { max-width: 980px; margin: 0 auto; padding: 0 2rem; }
  .highlight-info { padding: 0; }
  .highlight-project-title { font-family: var(--font-title); font-size: clamp(2rem, 5vw, 3.5rem); color: #000000; text-transform: uppercase; margin-bottom: 0.5rem; line-height: 1.1; }
  .highlight-project-desc { font-family: var(--font-title); font-size: clamp(0.85rem, 2vw, 1.15rem); color: #444444; text-transform: uppercase; margin-bottom: 0.2rem; line-height: 1.5; }

  .highlight-fade-out {
    position: relative; z-index: 10; height: 30vh; background: linear-gradient(to bottom, #ffffff 0%, transparent 100%);
  }

  @media (max-width: 640px) {
    .highlight-heading { font-size: 2.5rem; }
    .highlight-project-title { font-size: 1.8rem; }
    .glass-wall { -webkit-mask-size: 75vw auto, 100% 100%; }
  }
</style>

<script is:inline>
  // ============================================
  //  THE 3D CAMERA ENGINE & EMBEDDED CANVAS
  // ============================================
  (function() {
    var world = document.getElementById('world');
    var glassWall = document.getElementById('glass-wall');
    var layerHero = document.getElementById('layer-hero');
    var layerHighlight = document.getElementById('layer-highlight');
    var canvas = document.getElementById('portal-canvas');
    var ctx = canvas ? canvas.getContext('2d') : null;
    
    // -- 1. Embedded Canvas Trace Engine --
    const LOGO_PATH = 'M740.999,478.013 C732.574,479.445 726.913,485.562 720.161,489.579 C712.414,494.187 704.845,499.102 697.298,504.036 C692.012,507.492 686.547,510.801 681.777,514.892 C674.551,521.090 667.873,527.928 660.935,534.464 C654.627,540.404 648.340,546.368 641.928,552.195 C639.013,554.844 635.485,556.876 632.823,559.735 C627.664,565.276 622.951,571.231 617.999,576.966 C611.902,584.025 605.341,590.729 599.758,598.169 C595.680,603.603 591.923,609.316 589.345,615.895 C586.196,623.934 581.278,631.263 577.628,639.132 C575.564,643.581 574.522,648.502 572.996,653.202 C571.465,657.920 569.905,662.628 568.356,667.339 C568.256,667.642 568.004,667.957 568.045,668.234 C569.180,675.956 563.976,674.825 559.098,675.090 C545.363,675.834 531.422,675.836 518.020,678.466 C510.688,679.905 503.644,679.769 496.516,679.888 C461.607,680.469 426.579,679.030 391.812,681.458 C356.639,683.914 321.572,682.024 286.473,682.919 C257.736,683.651 228.980,683.617 200.234,684.019 C184.150,684.245 168.069,684.716 151.986,684.988 C129.572,685.368 107.157,685.739 84.741,685.946 C79.477,685.995 75.828,682.500 72.505,678.891 C71.964,678.304 71.809,676.901 72.095,676.095 C73.272,672.776 74.624,669.514 76.028,666.282 C79.981,657.187 83.997,648.119 87.978,639.036 C92.523,628.667 97.115,618.317 101.567,607.908 C103.141,604.229 104.237,600.347 105.774,596.651 C109.775,587.026 113.968,577.481 117.948,567.847 C120.196,562.404 122.038,556.792 124.309,551.358 C127.095,544.691 130.291,538.194 133.020,531.504 C134.939,526.798 136.209,521.830 138.071,517.098 C139.877,512.507 141.862,507.960 144.139,503.587 C147.600,496.940 151.181,490.338 155.090,483.949 C158.234,478.810 162.091,474.112 165.357,469.042 C169.395,462.771 172.954,456.189 177.079,449.979 C181.603,443.167 186.668,436.715 191.241,429.934 C194.070,425.740 196.243,421.106 199.027,416.879 C203.584,409.962 208.472,403.264 213.075,396.376 C215.326,393.009 216.687,388.884 219.421,386.033 C229.376,375.650 239.777,365.698 249.936,355.509 C256.358,349.067 262.390,342.209 269.107,336.098 C272.430,333.075 276.849,331.217 280.868,329.007 C290.026,323.972 299.206,318.976 308.446,314.095 C316.772,309.695 324.964,304.916 333.647,301.360 C339.508,298.959 346.158,298.540 352.385,296.958 C359.025,295.271 365.667,293.512 372.154,291.330 C382.317,287.911 392.847,287.437 403.361,287.054 C426.521,286.213 449.703,285.931 472.853,284.882 C483.476,284.400 493.720,285.910 504.024,287.915 C507.539,288.599 511.188,288.584 514.769,288.950 C521.210,289.609 527.711,289.960 534.066,291.113 C539.058,292.019 543.933,293.752 548.738,295.463 C553.265,297.075 557.640,299.117 562.066,301.007 C566.924,303.081 571.821,305.076 576.597,307.327 C582.149,309.943 587.534,312.913 593.089,315.523 C600.764,319.129 609.275,321.490 616.071,326.301 C624.695,332.407 634.338,336.107 643.456,341.000 C654.417,346.882 665.312,352.890 676.352,358.620 C681.614,361.350 687.229,363.394 692.531,366.053 C698.779,369.185 704.857,372.654 711.020,375.957 C711.783,376.366 712.597,376.916 713.411,376.959 C721.158,377.360 728.908,377.735 736.662,377.984 C748.910,378.377 761.167,378.531 773.410,379.040 C785.084,379.525 796.741,380.404 808.412,380.978 C817.490,381.424 826.582,381.588 835.662,382.019 C848.105,382.610 860.547,383.264 872.977,384.082 C874.690,384.195 876.413,385.251 877.992,386.124 C884.449,389.693 890.880,393.313 897.263,397.013 C899.923,398.555 902.505,400.252 905.010,402.037 C910.838,406.190 917.701,408.722 922.423,414.653 C927.559,421.104 933.497,426.916 939.744,433.723 C930.994,434.880 922.980,435.952 914.962,436.997 C907.107,438.020 898.921,437.982 891.489,440.334 C885.024,442.380 878.619,442.033 872.225,442.975 C864.687,444.085 857.104,444.899 849.573,446.050 C844.327,446.852 839.135,448.016 833.916,448.999 C828.536,450.013 823.152,451.007 817.768,452.002 C812.061,453.055 806.188,453.567 800.686,455.277 C793.217,457.600 786.012,460.787 778.730,463.693 C771.333,466.646 764.039,469.867 756.587,472.669 C751.510,474.578 746.238,475.968 740.999,478.013 Z';
    function sampleSVGPath(pathD, numSamples) {
      const ns = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(ns, 'svg');
      svg.setAttribute('viewBox', '0 0 1000 1000');
      svg.style.position = 'absolute'; svg.style.width = '0'; svg.style.height = '0'; svg.style.overflow = 'hidden';
      const path = document.createElementNS(ns, 'path');
      path.setAttribute('d', pathD);
      svg.appendChild(path); document.body.appendChild(svg);
      const totalLen = path.getTotalLength();
      const raw = [];
      for (let i = 0; i < numSamples; i++) {
        const pt = path.getPointAtLength((i / numSamples) * totalLen);
        raw.push({ x: pt.x, y: pt.y });
      }
      document.body.removeChild(svg);
      let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
      raw.forEach(p => { if (p.x < minX) minX = p.x; if (p.x > maxX) maxX = p.x; if (p.y < minY) minY = p.y; if (p.y > maxY) maxY = p.y; });
      const bw = maxX - minX || 1, bh = maxY - minY || 1;
      return raw.map(p => ({ x: (p.x - minX) / bw, y: (p.y - minY) / bh }));
    }

    class Particle {
      constructor(x, y) {
        this.x = x; this.y = y; this.baseX = x;
        this.vy = -(0.3 + Math.random() * 0.8); this.vx = (Math.random() - 0.5) * 0.4;
        this.life = 1; this.decay = 0.003 + Math.random() * 0.005; this.size = 0.5 + Math.random() * 1.5;
      }
      update() { this.x += this.vx; this.y += this.vy; this.life -= this.decay; }
      draw(ctx) {
        if (this.life <= 0) return;
        ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(193, 17, 17, ' + (this.life * 0.4).toFixed(3) + ')';
        ctx.fill();
      }
    }

    class Trace {
      constructor(pathPoints, speed, delay, color, width) {
        this.pathPoints = pathPoints; this.pathLen = pathPoints.length; this.speed = speed; this.delay = delay;
        this.color = color; this.baseWidth = width; this.progress = Math.random() * pathPoints.length;
        this.tailLen = 60 + Math.random() * 40; this.active = false; this.opacity = 1;
      }
      update(time) {
        if (time < this.delay) return;
        this.active = true; this.progress += this.speed;
        if (this.progress >= this.pathLen) this.progress -= this.pathLen;
      }
      draw(ctx) {
        if (!this.active || this.opacity < 0.01) return;
        const headIdx = Math.floor(this.progress) % this.pathLen;
        const segments = 8, segLen = Math.floor(this.tailLen / segments);
        for (let s = segments - 1; s >= 0; s--) {
          const tFade = 1 - (s / segments);
          const alpha = tFade * tFade * 0.55 * this.opacity;
          const width = this.baseWidth * (0.2 + tFade * 0.8);
          ctx.beginPath();
          const startI = s * segLen, endI = Math.min((s + 1) * segLen + 1, this.tailLen);
          for (let i = startI; i < endI; i++) {
            const idx = (headIdx - i + this.pathLen) % this.pathLen;
            const pt = this.pathPoints[idx];
            if (i === startI) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y);
          }
          ctx.strokeStyle = this.color.replace('ALPHA', alpha.toFixed(3));
          ctx.lineWidth = width; ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.stroke();
        }
      }
    }

    let W, H, pathPoints = [], traces = [], particles = [];
    const normPoints = sampleSVGPath(LOGO_PATH, 300);
    const traceConfigs = [
      { spd: 1.0, delay: 100, col: 'rgba(193, 17, 17, ALPHA)', w: 2.0 }, { spd: 0.75, delay: 400, col: 'rgba(193, 17, 17, ALPHA)', w: 1.6 },
      { spd: 1.15, delay: 800, col: 'rgba(220, 60, 60, ALPHA)', w: 1.4 }, { spd: 0.9, delay: 1200, col: 'rgba(255, 255, 255, ALPHA)', w: 1.5 },
      { spd: 0.65, delay: 200, col: 'rgba(160, 30, 30, ALPHA)', w: 1.2 }, { spd: 0.8, delay: 600, col: 'rgba(193, 17, 17, ALPHA)', w: 0.8 },
      { spd: 1.05, delay: 1000, col: 'rgba(220, 60, 60, ALPHA)', w: 1.8 }, { spd: 0.7, delay: 300, col: 'rgba(255, 255, 255, ALPHA)', w: 1.3 }
    ];

    function resizeCanvas() {
      if(!canvas) return;
      
      // The canvas is 200vw by 200vh. Multiply innerWidth by 2 to get its absolute pixel width.
      W = canvas.width = window.innerWidth * 2;
      H = canvas.height = window.innerHeight * 2;
      
      const aspect = 2.16;
      let maskW = window.innerWidth * 0.40; 
      if (window.innerWidth <= 640) maskW = window.innerWidth * 0.75; // Mobile CSS mask sizing
      const maskH = maskW / aspect;
      
      // Because W is 200vw, W/2 is exactly the center of the viewport.
      pathPoints = normPoints.map(p => ({
        x: W/2 + (p.x - 0.5) * maskW,
        y: H/2 + (p.y - 0.5) * maskH
      }));
      
      traces = traceConfigs.map(c => new Trace(pathPoints, c.spd, c.delay, c.col, c.w));
    }
    
    if (canvas) {
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);
      
      const startTime = performance.now();
      function animatePortal(now) {
        requestAnimationFrame(animatePortal);
        const elapsed = now - startTime;
        ctx.clearRect(0, 0, W, H);

        // 1. Draw central glowing aura
        const pc = { x: W/2, y: H/2 };
        const r = Math.min(W, H) * 0.6 * (1 + Math.sin(elapsed * 0.0005) * 0.08);
        const glow = ctx.createRadialGradient(pc.x, pc.y, 0, pc.x, pc.y, r);
        glow.addColorStop(0, 'rgba(193, 17, 17, 0.12)'); glow.addColorStop(0.3, 'rgba(193, 17, 17, 0.06)');
        glow.addColorStop(0.6, 'rgba(160, 30, 30, 0.025)'); glow.addColorStop(1, 'rgba(0, 0, 0, 0)');
        ctx.fillStyle = glow; ctx.fillRect(0, 0, W, H);

        // 2. Draw Traces perfectly around the hole
        traces.forEach(t => { t.update(elapsed); t.draw(ctx); });

        // 3. Embers
        if (particles.length < 80 && Math.random() < 0.3) {
          var randomTrace = traces[Math.floor(Math.random() * traces.length)];
          if (randomTrace.active) {
            var headIdx = Math.floor(randomTrace.progress) % randomTrace.pathLen;
            particles.push(new Particle(randomTrace.pathPoints[headIdx].x, randomTrace.pathPoints[headIdx].y));
          }
        }
        for (var pi = particles.length - 1; pi >= 0; pi--) {
          particles[pi].update();
          if (particles[pi].life <= 0) particles.splice(pi, 1);
          else particles[pi].draw(ctx);
        }
      }
      requestAnimationFrame(animatePortal);
    }

    // -- 2. Scroll 3D Zoom & Scrub Engine --
    var img = document.getElementById('cinematic-sequence');
    var placeholder = document.getElementById('cinematic-placeholder');
    var totalFrames = 60;

    function getFrameUrl(frameNum) { return `/animation/frame_${frameNum}.jpg`; }

    for(var i = 1; i <= 15; i++) { var pre = new Image(); pre.src = getFrameUrl(i); }
    if (img) {
      img.src = getFrameUrl(1);
      img.onload = function() { if(placeholder) placeholder.style.display = 'none'; };
    }

    window.addEventListener('scroll', function() {
      var vh = window.innerHeight;
      var y = window.scrollY;
      
      // --- PHASE 1: 3D PORTAL ZOOM (0 to 200vh) ---
      var zoomEnd = vh * 2;
      var zoomP = Math.max(0, Math.min(1, y / zoomEnd));
      
      // Camera moves from Z=0 to Z=2000
      var cameraZ = zoomP * 2000;
      if (world) world.style.transform = 'translateZ(' + cameraZ + 'px)';
      
      // Defrost the glass as we approach the window (Z=1000)
      var windowProximity = Math.max(0, Math.min(1, (cameraZ - 400) / 600));
      if (glassWall) glassWall.style.backdropFilter = 'blur(' + (15 * (1 - windowProximity)) + 'px)';
      
      // Fade out Hero layer so it doesn't clip the camera
      var heroOpacity = 1 - Math.max(0, Math.min(1, (cameraZ - 400) / 400));
      if (layerHero) {
        layerHero.style.opacity = heroOpacity;
        layerHero.style.pointerEvents = heroOpacity < 0.1 ? 'none' : 'auto';
      }
      
      // Fade in Highlight layer so it glows gracefully in the distance
      if (layerHighlight) layerHighlight.style.opacity = Math.max(0, Math.min(1, (cameraZ - 500) / 1000));
      
      // Hard hide the portal layer once we pass perfectly through to avoid weird edge clipping bugs
      if (layerWindow = document.getElementById('layer-window')) {
          layerWindow.style.opacity = cameraZ > 1950 ? 0 : 1;
      }

      // --- PHASE 2: CINEMATIC VIDEO SCRUB (200vh to 350vh) ---
      var scrubStart = vh * 2;
      var scrubDuration = vh * 1.5;
      var scrubP = y > scrubStart ? (y - scrubStart) / scrubDuration : 0;
      scrubP = Math.max(0, Math.min(1, scrubP));
      
      if (img) {
        var frame = Math.max(1, Math.min(totalFrames, Math.ceil(scrubP * totalFrames)));
        var targetSrc = getFrameUrl(frame);
        if (img.getAttribute('src') !== targetSrc) img.setAttribute('src', targetSrc);
      }
    }, { passive: true });
  })();

  // ============================================
  //  SLOT MACHINE REEL
  // ============================================
  (function() {
    var reel = document.getElementById('hero-reel');
    if (!reel) return;
    var words = reel.querySelectorAll('.reel-word');
    var totalWords = words.length;
    var wordH = words[0].offsetHeight;
    var lastIdx = totalWords - 1;

    function scrollToWord(idx) {
      var offset = idx * wordH;
      if (idx < lastIdx) {
        var delay = 10 + Math.sin((idx / lastIdx) * (Math.PI / 2)) * 180;
        reel.style.transition = 'transform ' + delay + 'ms linear';
        reel.style.transform = 'translateY(-' + offset + 'px)';
        setTimeout(function() { scrollToWord(idx + 1); }, delay);
      } else {
        reel.style.transition = 'transform 600ms cubic-bezier(0.25, 1.2, 0.5, 1)';
        reel.style.transform = 'translateY(-' + offset + 'px)';
      }
    }
    setTimeout(function() { scrollToWord(1); }, 400);
  })();

  // ============================================
  //  FLOATING SINE WAVE — nav pills
  // ============================================
  (function() {
    var all = [].slice.call(document.querySelectorAll('#nav-cards .nav-pill'))
                .concat([].slice.call(document.querySelectorAll('#ext-row .ext-chip')));
    var exploreTag = document.getElementById('explore-tag');
    if (exploreTag) all.push(exploreTag);

    var startTime = performance.now();
    function animateFloat(time) {
      var decay = Math.max(0.08, 1 - (time - startTime) / 6000);
      all.forEach(function(el) {
        var y = Math.sin(time * 0.0015 + parseFloat(el.dataset.phase || '0')) * (5 * decay);
        el.style.transform = 'translateY(' + y.toFixed(2) + 'px)';
      });
      requestAnimationFrame(animateFloat);
    }
    requestAnimationFrame(animateFloat);
  })();

  // ============================================
  //  INTERACTIVE STAR FLOOD (Dark Stars on White)
  // ============================================
  (function() {
    var container = document.getElementById('highlight-star-flood');
    if (!container) return;
    var canvas = document.createElement('canvas');
    canvas.style.width = '100%'; canvas.style.height = '100%';
    container.appendChild(canvas);
    var ctx = canvas.getContext('2d'), W, H, floodStars = [], mouseX = -1000, mouseY = -1000;

    function resize() {
      W = canvas.width = container.clientWidth; H = canvas.height = container.clientHeight;
      floodStars = [];
      for (var x = 20; x < W; x += 40) {
        for (var y = 20; y < H; y += 40) {
          floodStars.push({ baseX: x, baseY: y, size: 2.0 + Math.random() * 2.5, twinkle: Math.random() * Math.PI * 2 });
        }
      }
    }
    resize(); window.addEventListener('resize', resize);
    window.addEventListener('mousemove', function(e) {
      var rect = canvas.getBoundingClientRect(); mouseX = e.clientX - rect.left; mouseY = e.clientY - rect.top;
    });

    function animate(now) {
      requestAnimationFrame(animate);
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = 'rgba(0, 0, 0, 0.15)'; ctx.beginPath();
      
      for (var i = 0; i < floodStars.length; i++) {
        var s = floodStars[i], sx = s.baseX, sy = s.baseY, mdx = sx - mouseX, mdy = sy - mouseY, mDistSq = mdx * mdx + mdy * mdy;
        if (mDistSq < 6400 && mDistSq > 0) {
          var mDist = Math.sqrt(mDistSq), force = (1 - mDist / 80) * 15;
          sx += (mdx / mDist) * force; sy += (mdy / mDist) * force;
        }
        var alpha = 0.5 + 0.5 * Math.sin(now * 0.002 + s.twinkle);
        ctx.moveTo(sx + s.size, sy); ctx.arc(sx, sy, s.size * alpha, 0, Math.PI * 2);
      }
      ctx.fill();
    }
    requestAnimationFrame(animate);
  })();
</script>
