---
/**
 * BackgroundEffects.astro — Full-screen canvas animation layer
 *
 * Renders behind all page content to create the atmospheric environment.
 * Re-architected to allow the 3D CSS portals on the homepage to sit 
 * seamlessly on top without causing "double-vision" rendering bugs.
 *
 * Layers:
 * 1. Dot grid texture (cached offscreen)
 * 2. Twinkling star field with mouse repulsion
 * 3. Wavy aurora strands with parallax
 * 4. Diagonal shooting stars
 */
---
<canvas id="bg-canvas"></canvas>
<div id="grain-overlay"></div>

<style>
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    background: #000000;
  }

  #grain-overlay {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }
</style>

<script is:inline>
(function() {
  const canvas = document.getElementById('bg-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  let W, H;
  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // --- Wavy Aurora Strand ---
  class AuroraBand {
    constructor(y, color, width, speed, amp, freq, offset) {
      this.baseY = y;
      this.color = color;
      this.width = width;
      this.speed = speed;
      this.amp = amp;
      this.freq = freq;
      this.offset = offset;
      this.opacity = 0;
      this.targetOpacity = 0.12 + Math.random() * 0.1;
      this.freq2 = freq * 2.3 + Math.random() * 1.5;
      this.amp2 = amp * 0.35;
      this.offset2 = offset * 1.7 + Math.random();
    }
    update(time) {
      if (this.opacity < this.targetOpacity) this.opacity += 0.002;
    }
    draw(ctx, time, W, H) {
      if (this.opacity < 0.01) return;
      ctx.beginPath();
      const steps = 50;
      const timeF = time * this.speed * 0.0008;
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        const x = t * W;
        const wave1 = Math.sin(t * this.freq + timeF + this.offset) * this.amp;
        const wave2 = Math.sin(t * this.freq2 + timeF * 0.7 + this.offset2) * this.amp2;
        const y = this.baseY + wave1 + wave2;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.strokeStyle = this.color.replace('ALPHA', this.opacity.toFixed(3));
      ctx.lineWidth = this.width;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.stroke();
    }
  }

  // --- Shooting Star ---
  class ShootingStar {
    constructor(clustered) { this.reset(clustered); }
    reset(clustered) {
      var startX = W * (0.5 + Math.random() * 0.6);
      var startY = -20 - Math.random() * H * 0.3;
      if (clustered) {
        startX += (Math.random() - 0.5) * W * 0.15;
        startY += (Math.random() - 0.5) * H * 0.1;
      }
      this.x = startX;
      this.y = startY;
      var angle = Math.PI * (0.65 + Math.random() * 0.2);
      this.speed = 2.5 + Math.random() * 4;
      this.vx = Math.cos(angle) * this.speed;
      this.vy = Math.sin(angle) * this.speed;
      
      // DOUBLED: Shooting Star Size & Trail
      this.tailLen = (40 + Math.random() * 60) * 1.5; 
      this.width = (0.6 + Math.random() * 1.8) * 2.0; 
      
      this.life = 1;
      this.decay = 0.004 + Math.random() * 0.006;
      this.isWhite = Math.random() < 0.33;
      this.active = true;
    }
    update() {
      if (!this.active) return;
      this.x += this.vx; this.y += this.vy;
      this.life -= this.decay;
      if (this.life <= 0 || this.x < -100 || this.y > H + 100) this.active = false;
    }
    draw(ctx) {
      if (!this.active || this.life <= 0) return;
      var tailX = this.x - this.vx * this.tailLen / this.speed;
      var tailY = this.y - this.vy * this.tailLen / this.speed;
      var segments = 6;
      for (var s = segments - 1; s >= 0; s--) {
        var t0 = s / segments; var t1 = (s + 1) / segments;
        var x0 = tailX + (this.x - tailX) * t0; var y0 = tailY + (this.y - tailY) * t0;
        var x1 = tailX + (this.x - tailX) * t1; var y1 = tailY + (this.y - tailY) * t1;
        var alpha = t1 * t1 * this.life * 0.6;
        var w = this.width * (0.15 + t1 * 0.85);
        ctx.beginPath();
        ctx.moveTo(x0, y0);
        ctx.lineTo(x1, y1);
        ctx.strokeStyle = this.isWhite 
          ? 'rgba(255, 255, 255, ' + alpha.toFixed(3) + ')'
          : 'rgba(193, 17, 17, ' + alpha.toFixed(3) + ')';
        ctx.lineWidth = w;
        ctx.lineCap = 'round';
        ctx.stroke();
      }
    }
  }

  // --- Initialization ---
  const redColor = 'rgba(193, 17, 17, ALPHA)';
  const softRed = 'rgba(220, 60, 60, ALPHA)';
  const dimRed = 'rgba(160, 30, 30, ALPHA)';
  const brightWhite = 'rgba(255, 255, 255, ALPHA)';

  let auroraBands = [];
  let stars = [];
  let scrollY = 0;
  let mouseX = -1000, mouseY = -1000;
  let mouseActive = false;

  window.addEventListener('mousemove', function(e) { mouseX = e.clientX; mouseY = e.clientY; mouseActive = true; });
  document.addEventListener('mouseleave', function() { mouseActive = false; });
  window.addEventListener('scroll', function() { scrollY = window.scrollY || window.pageYOffset; }, { passive: true });

  let gridCanvas = null;
  function buildGridTexture() {
    gridCanvas = document.createElement('canvas');
    gridCanvas.width = W; gridCanvas.height = H;
    const gc = gridCanvas.getContext('2d');
    gc.fillStyle = 'rgba(255, 255, 255, 0.015)';
    for (let x = 40; x < W; x += 40) {
      for (let y = 40; y < H; y += 40) {
        gc.beginPath(); gc.arc(x, y, 0.6, 0, Math.PI * 2); gc.fill();
      }
    }
  }

  function buildAurora() {
    auroraBands = [];
    const colors = [redColor, softRed, brightWhite, dimRed, redColor, softRed, brightWhite, dimRed, softRed, redColor, brightWhite, dimRed, redColor, softRed, brightWhite, softRed];
    for (let i = 0; i < 16; i++) {
      const band = new AuroraBand(H * (0.04 + (i / 16) * 0.92), colors[i], 0.8 + Math.random() * 1.8, 0.1 + Math.random() * 0.4, 15 + Math.random() * 30, 1.0 + Math.random() * 3.0, i * 0.8 + Math.random() * 0.5);
      if (colors[i] === brightWhite) band.targetOpacity = 0.18 + Math.random() * 0.12;
      auroraBands.push(band);
    }
  }

  function buildStarField() {
    stars = [];
    for (let x = 15; x < W; x += 30) {
      for (let y = 15; y < H; y += 30) {
        stars.push({ 
          baseX: x, baseY: y, 
          x: x, y: y, 
          // DOUBLED: Background Star Size
          size: 1.6 + Math.random() * 1.6, 
          twinkle: Math.random() * Math.PI * 2 
        });
      }
    }
  }

  var shootingStars = [], lastShootTime = 0, nextShootDelay = 2000 + Math.random() * 3000, clusterCount = 0, inCluster = false;
  function spawnShootingStar(elapsed) {
    if (elapsed - lastShootTime < nextShootDelay) return;
    lastShootTime = elapsed;
    if (!inCluster && Math.random() < 0.4) { inCluster = true; clusterCount = 2 + Math.floor(Math.random() * 4); }
    if (inCluster) {
      shootingStars.push(new ShootingStar(true)); clusterCount--;
      nextShootDelay = 80 + Math.random() * 250;
      if (clusterCount <= 0) { inCluster = false; nextShootDelay = 3000 + Math.random() * 5000; }
    } else {
      shootingStars.push(new ShootingStar(false)); nextShootDelay = 2000 + Math.random() * 4000;
    }
    if (shootingStars.length > 20) shootingStars = shootingStars.filter(function(s) { return s.active; });
  }

  buildGridTexture(); buildAurora(); buildStarField();

  // --- Render Loop ---
  const startTime = performance.now();
  let lastFrame = 0;
  const FRAME_TIME = 1000 / 30;

  function animate(now) {
    requestAnimationFrame(animate);
    if (now - lastFrame < FRAME_TIME) return;
    lastFrame = now;

    const elapsed = now - startTime;
    ctx.clearRect(0, 0, W, H);
    if (gridCanvas) ctx.drawImage(gridCanvas, 0, 0);

    // Interactive Starfield
    // DOUBLED: Global Star Brightness Alpha
    ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
    ctx.beginPath();
    for (var si2 = 0; si2 < stars.length; si2++) {
      var s2 = stars[si2];
      var sx2 = s2.baseX; var sy2 = s2.baseY;
      if (mouseActive) {
        var mdx2 = sx2 - mouseX, mdy2 = sy2 - mouseY, mDist2 = mdx2 * mdx2 + mdy2 * mdy2;
        if (mDist2 < 6400 && mDist2 > 0) {
          var mDistReal = Math.sqrt(mDist2);
          var force2 = (1 - mDistReal / 80) * 15;
          sx2 += (mdx2 / mDistReal) * force2; sy2 += (mdy2 / mDistReal) * force2;
        }
      }
      s2.x = sx2; s2.y = sy2;
      var twinkle2 = 0.15 + 0.2 * Math.sin(elapsed * 0.002 + s2.twinkle);
      ctx.moveTo(sx2 + s2.size * 0.7, sy2);
      ctx.arc(sx2, sy2, s2.size * 0.7, 0, Math.PI * 2);
    }
    ctx.fill();

    // Aurora Strands
    ctx.save();
    ctx.translate(0, -scrollY * 0.075);
    auroraBands.forEach(function(b) { b.update(elapsed); b.draw(ctx, elapsed, W, H); });
    ctx.restore();

    // Shooting Stars
    spawnShootingStar(elapsed);
    for (var ssi = shootingStars.length - 1; ssi >= 0; ssi--) {
      shootingStars[ssi].update();
      if (!shootingStars[ssi].active) shootingStars.splice(ssi, 1);
      else shootingStars[ssi].draw(ctx);
    }
  }

  requestAnimationFrame(animate);

  window.addEventListener('resize', function() {
    resize(); buildGridTexture(); buildStarField(); buildAurora();
  });
})();
</script>
