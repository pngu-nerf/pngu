---
/**
 * BackgroundEffects.astro — Full-screen canvas animation layer
 *
 * Renders behind all page content with two distinct modes:
 *
 * HOMEPAGE (isHome):
 *   1. Dot grid texture (cached offscreen)
 *   2. Wavy aurora strands with parallax scroll
 *   3. Red glow behind penguin silhouette
 *   4. Frosted glass interior (Apple-style) with mouse glow
 *   5. Tapering traces running along the PNGU logo SVG path
 *   6. Rising particles spawned from trace heads
 *   7. Mouse proximity ripple effect
 *
 * SUB-PAGES (contact, brand, files, data, 404):
 *   1. Dot grid texture
 *   2. Twinkling star field with mouse repulsion (back layer)
 *   3. Wavy aurora strands (mid layer)
 *   4. Diagonal shooting stars in clusters (front layer)
 *
 * Performance notes:
 *   - Capped at 30fps via FRAME_TIME throttle
 *   - Dot grid is pre-rendered to offscreen canvas (buildGridTexture)
 *   - Stars are batched into a single beginPath/fill call
 *   - Mouse distance uses squared comparison to avoid sqrt when possible
 */
---
<!-- Fixed full-screen background canvas -->
<canvas id="bg-canvas"></canvas>
<!-- Subtle film grain overlay for texture depth -->
<div id="grain-overlay"></div>

<style>
  /* Canvas covers entire viewport behind all content */
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    background: #000000;
  }

  /* SVG noise texture overlaid at very low opacity for film grain feel */
  #grain-overlay {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }
</style>

<script is:inline>
(function() {
  const canvas = document.getElementById('bg-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  // Detect homepage vs sub-pages for different animation modes
  const isHome = window.location.pathname === '/' || window.location.pathname === '';

  let W, H;
  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // --- Exact PNGU logo SVG path (from user-provided SVG file) ---
  // This path data defines the penguin head silhouette used for trace animations.
  const LOGO_PATH = 'M740.999,478.013 C732.574,479.445 726.913,485.562 720.161,489.579 C712.414,494.187 704.845,499.102 697.298,504.036 C692.012,507.492 686.547,510.801 681.777,514.892 C674.551,521.090 667.873,527.928 660.935,534.464 C654.627,540.404 648.340,546.368 641.928,552.195 C639.013,554.844 635.485,556.876 632.823,559.735 C627.664,565.276 622.951,571.231 617.999,576.966 C611.902,584.025 605.341,590.729 599.758,598.169 C595.680,603.603 591.923,609.316 589.345,615.895 C586.196,623.934 581.278,631.263 577.628,639.132 C575.564,643.581 574.522,648.502 572.996,653.202 C571.465,657.920 569.905,662.628 568.356,667.339 C568.256,667.642 568.004,667.957 568.045,668.234 C569.180,675.956 563.976,674.825 559.098,675.090 C545.363,675.834 531.422,675.836 518.020,678.466 C510.688,679.905 503.644,679.769 496.516,679.888 C461.607,680.469 426.579,679.030 391.812,681.458 C356.639,683.914 321.572,682.024 286.473,682.919 C257.736,683.651 228.980,683.617 200.234,684.019 C184.150,684.245 168.069,684.716 151.986,684.988 C129.572,685.368 107.157,685.739 84.741,685.946 C79.477,685.995 75.828,682.500 72.505,678.891 C71.964,678.304 71.809,676.901 72.095,676.095 C73.272,672.776 74.624,669.514 76.028,666.282 C79.981,657.187 83.997,648.119 87.978,639.036 C92.523,628.667 97.115,618.317 101.567,607.908 C103.141,604.229 104.237,600.347 105.774,596.651 C109.775,587.026 113.968,577.481 117.948,567.847 C120.196,562.404 122.038,556.792 124.309,551.358 C127.095,544.691 130.291,538.194 133.020,531.504 C134.939,526.798 136.209,521.830 138.071,517.098 C139.877,512.507 141.862,507.960 144.139,503.587 C147.600,496.940 151.181,490.338 155.090,483.949 C158.234,478.810 162.091,474.112 165.357,469.042 C169.395,462.771 172.954,456.189 177.079,449.979 C181.603,443.167 186.668,436.715 191.241,429.934 C194.070,425.740 196.243,421.106 199.027,416.879 C203.584,409.962 208.472,403.264 213.075,396.376 C215.326,393.009 216.687,388.884 219.421,386.033 C229.376,375.650 239.777,365.698 249.936,355.509 C256.358,349.067 262.390,342.209 269.107,336.098 C272.430,333.075 276.849,331.217 280.868,329.007 C290.026,323.972 299.206,318.976 308.446,314.095 C316.772,309.695 324.964,304.916 333.647,301.360 C339.508,298.959 346.158,298.540 352.385,296.958 C359.025,295.271 365.667,293.512 372.154,291.330 C382.317,287.911 392.847,287.437 403.361,287.054 C426.521,286.213 449.703,285.931 472.853,284.882 C483.476,284.400 493.720,285.910 504.024,287.915 C507.539,288.599 511.188,288.584 514.769,288.950 C521.210,289.609 527.711,289.960 534.066,291.113 C539.058,292.019 543.933,293.752 548.738,295.463 C553.265,297.075 557.640,299.117 562.066,301.007 C566.924,303.081 571.821,305.076 576.597,307.327 C582.149,309.943 587.534,312.913 593.089,315.523 C600.764,319.129 609.275,321.490 616.071,326.301 C624.695,332.407 634.338,336.107 643.456,341.000 C654.417,346.882 665.312,352.890 676.352,358.620 C681.614,361.350 687.229,363.394 692.531,366.053 C698.779,369.185 704.857,372.654 711.020,375.957 C711.783,376.366 712.597,376.916 713.411,376.959 C721.158,377.360 728.908,377.735 736.662,377.984 C748.910,378.377 761.167,378.531 773.410,379.040 C785.084,379.525 796.741,380.404 808.412,380.978 C817.490,381.424 826.582,381.588 835.662,382.019 C848.105,382.610 860.547,383.264 872.977,384.082 C874.690,384.195 876.413,385.251 877.992,386.124 C884.449,389.693 890.880,393.313 897.263,397.013 C899.923,398.555 902.505,400.252 905.010,402.037 C910.838,406.190 917.701,408.722 922.423,414.653 C927.559,421.104 933.497,426.916 939.744,433.723 C930.994,434.880 922.980,435.952 914.962,436.997 C907.107,438.020 898.921,437.982 891.489,440.334 C885.024,442.380 878.619,442.033 872.225,442.975 C864.687,444.085 857.104,444.899 849.573,446.050 C844.327,446.852 839.135,448.016 833.916,448.999 C828.536,450.013 823.152,451.007 817.768,452.002 C812.061,453.055 806.188,453.567 800.686,455.277 C793.217,457.600 786.012,460.787 778.730,463.693 C771.333,466.646 764.039,469.867 756.587,472.669 C751.510,474.578 746.238,475.968 740.999,478.013 Z';

  /**
   * Sample evenly-spaced points from an SVG path string.
   * Creates a temporary invisible SVG element, uses getPointAtLength() to
   * sample numSamples points, then normalizes all coordinates to 0-1 range
   * within the path's bounding box. This allows scaling to any screen size.
   */
  function sampleSVGPath(pathD, numSamples) {
    const ns = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(ns, 'svg');
    svg.setAttribute('viewBox', '0 0 1000 1000');
    svg.style.position = 'absolute';
    svg.style.width = '0';
    svg.style.height = '0';
    svg.style.overflow = 'hidden';
    const path = document.createElementNS(ns, 'path');
    path.setAttribute('d', pathD);
    svg.appendChild(path);
    document.body.appendChild(svg);

    const totalLen = path.getTotalLength();
    const raw = [];
    for (let i = 0; i < numSamples; i++) {
      const pt = path.getPointAtLength((i / numSamples) * totalLen);
      raw.push({ x: pt.x, y: pt.y });
    }
    document.body.removeChild(svg);

    // Compute bounding box and normalize to 0-1
    let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    raw.forEach(p => {
      if (p.x < minX) minX = p.x;
      if (p.x > maxX) maxX = p.x;
      if (p.y < minY) minY = p.y;
      if (p.y > maxY) maxY = p.y;
    });
    const bw = maxX - minX || 1;
    const bh = maxY - minY || 1;
    return raw.map(p => ({
      x: (p.x - minX) / bw,
      y: (p.y - minY) / bh
    }));
  }

  /**
   * Scale normalized (0-1) path points to screen coordinates.
   * Centers the path at (cx, cy) with given width/height.
   */
  function scalePath(normPts, cx, cy, scaleW, scaleH) {
    return normPts.map(p => ({
      x: cx + (p.x - 0.5) * scaleW,
      y: cy + (p.y - 0.5) * scaleH
    }));
  }

  // --- Wavy Aurora Strand with double harmonics ---
  // Performance: pre-calculate wave points once per frame, batch draw calls
  class AuroraBand {
    constructor(y, color, width, speed, amp, freq, offset) {
      this.baseY = y;
      this.color = color;
      this.width = width;
      this.speed = speed;
      this.amp = amp;
      this.freq = freq;
      this.offset = offset;
      this.opacity = 0;
      this.targetOpacity = 0.12 + Math.random() * 0.1;
      // Second harmonic for more organic waviness
      this.freq2 = freq * 2.3 + Math.random() * 1.5;
      this.amp2 = amp * 0.35;
      this.offset2 = offset * 1.7 + Math.random();
      this.cachedPoints = [];
    }

    update(time) {
      if (this.opacity < this.targetOpacity) {
        this.opacity += 0.002;
      }
    }

    draw(ctx, time, W, H) {
      if (this.opacity < 0.01) return;

      ctx.beginPath();
      const steps = 50;
      const timeF = time * this.speed * 0.0008;
      
      // Pre-calculate all points for this frame
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        const x = t * W;
        const wave1 = Math.sin(t * this.freq + timeF + this.offset) * this.amp;
        const wave2 = Math.sin(t * this.freq2 + timeF * 0.7 + this.offset2) * this.amp2;
        const y = this.baseY + wave1 + wave2;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }

      ctx.strokeStyle = this.color.replace('ALPHA', this.opacity.toFixed(3));
      ctx.lineWidth = this.width;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.stroke();
    }
  }

  // --- Rising particle behind penguin ---
  // Small red dots that float upward from trace head positions,
  // creating a subtle ember/spark effect behind the silhouette.
  class Particle {
    constructor(x, y) {
      this.x = x;
      this.y = y;
      this.baseX = x;
      this.vy = -(0.3 + Math.random() * 0.8);
      this.vx = (Math.random() - 0.5) * 0.4;
      this.life = 1;
      this.decay = 0.003 + Math.random() * 0.005;
      this.size = 0.5 + Math.random() * 1.5;
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.life -= this.decay;
    }

    draw(ctx) {
      if (this.life <= 0) return;
      const a = this.life * 0.4;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(193, 17, 17, ' + a.toFixed(3) + ')';
      ctx.fill();
    }
  }

  // --- Fading/tapering trace (devin.ai style) ---
  // Traces follow the SVG path points, drawing 8 segments from tail to head.
  // Each segment progressively increases in opacity (quadratic) and width,
  // creating the characteristic tapering glow trail effect.
  class Trace {
    constructor(pathPoints, speed, delay, color, width) {
      this.pathPoints = pathPoints;
      this.pathLen = pathPoints.length;
      this.speed = speed;
      this.delay = delay;
      this.color = color;
      this.baseWidth = width;
      this.progress = Math.random() * pathPoints.length;
      this.tailLen = 60 + Math.random() * 40;
      this.active = false;
      this.opacity = 1;
    }

    update(time) {
      if (time < this.delay) return;
      this.active = true;
      this.progress += this.speed;
      if (this.progress >= this.pathLen) this.progress -= this.pathLen;
    }

    fadeOut() {
      this.opacity -= 0.02;
      if (this.opacity < 0) this.opacity = 0;
    }

    draw(ctx) {
      if (!this.active || this.opacity < 0.01) return;
      const headIdx = Math.floor(this.progress) % this.pathLen;
      const segments = 8;
      const segLen = Math.floor(this.tailLen / segments);

      // Draw tapering segments from tail to head — each segment fades and thins
      for (let s = segments - 1; s >= 0; s--) {
        const tFade = 1 - (s / segments); // 0 at tail, 1 at head
        const alpha = tFade * tFade * 0.55 * this.opacity; // quadratic fade
        const width = this.baseWidth * (0.2 + tFade * 0.8); // thin tail, full head

        ctx.beginPath();
        const startI = s * segLen;
        const endI = Math.min((s + 1) * segLen + 1, this.tailLen);
        for (let i = startI; i < endI; i++) {
          const idx = (headIdx - i + this.pathLen) % this.pathLen;
          const pt = this.pathPoints[idx];
          if (i === startI) ctx.moveTo(pt.x, pt.y);
          else ctx.lineTo(pt.x, pt.y);
        }
        ctx.strokeStyle = this.color.replace('ALPHA', alpha.toFixed(3));
        ctx.lineWidth = width;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.stroke();
      }
    }
  }

  // ============================================
  //  INITIALIZATION — Colors, paths, state
  // ============================================

  // Sample 300 evenly-spaced points from the logo SVG path
  const normPoints = sampleSVGPath(LOGO_PATH, 300);
  // Color templates — ALPHA placeholder is replaced at draw time
  const redColor = 'rgba(193, 17, 17, ALPHA)';     // Primary accent red
  const softRed = 'rgba(220, 60, 60, ALPHA)';       // Lighter red variant
  const dimRed = 'rgba(160, 30, 30, ALPHA)';         // Darker red variant
  const whiteColor = 'rgba(255, 255, 255, ALPHA)';   // White for 1/3 of strands
  const brightWhite = 'rgba(255, 255, 255, ALPHA)';  // Bright white (same template)

  let traces = [];
  let auroraBands = [];
  let pathPoints;
  let scrollY = 0;

  // Mouse interaction state
  let mouseX = -1000, mouseY = -1000;
  let mouseActive = false;
  window.addEventListener('mousemove', function(e) {
    mouseX = e.clientX;
    mouseY = e.clientY;
    mouseActive = true;
  });
  document.addEventListener('mouseleave', function() {
    mouseActive = false;
  });

  // Parallax scroll tracking
  window.addEventListener('scroll', function() {
    scrollY = window.scrollY || window.pageYOffset;
  }, { passive: true });

  // Dot grid texture — pre-rendered to offscreen canvas once,
  // then stamped onto the main canvas each frame via drawImage().
  // Much faster than drawing thousands of individual dots per frame.
  let gridCanvas = null;
  function buildGridTexture() {
    gridCanvas = document.createElement('canvas');
    gridCanvas.width = W;
    gridCanvas.height = H;
    const gc = gridCanvas.getContext('2d');
    gc.fillStyle = 'rgba(255, 255, 255, 0.015)';
    const spacing = 40;
    for (let x = spacing; x < W; x += spacing) {
      for (let y = spacing; y < H; y += spacing) {
        gc.beginPath();
        gc.arc(x, y, 0.6, 0, Math.PI * 2);
        gc.fill();
      }
    }
  }

  /**
   * Scale the normalized PNGU logo path to screen dimensions.
   * SVG viewBox is 1000x1000, actual path bbox ratio is ~2.16:1.
   * Centered slightly right (0.08 offset) with top of head at ~36% viewport height.
   */
  function buildPath() {
    const aspect = 2.16; // width:height ratio of the penguin path bbox
    const targetH = H * 0.5;
    const targetW = targetH * aspect;
    const finalW = Math.min(targetW, W * 0.85);
    const finalH = finalW / aspect;
    const cx = W * 0.5 + finalW * 0.08;
    const cy = H * 0.36;
    pathPoints = scalePath(normPoints, cx, cy, finalW, finalH);
    return pathPoints;
  }

  // Compute center of penguin path for glow positioning
  function getPathCenter() {
    if (!pathPoints || pathPoints.length < 3) return { x: W * 0.5, y: H * 0.36 };
    let sx = 0, sy = 0;
    pathPoints.forEach(p => { sx += p.x; sy += p.y; });
    return { x: sx / pathPoints.length, y: sy / pathPoints.length };
  }

  /**
   * Draw frosted glass interior — Apple-style translucent fill inside the penguin outline.
   * Uses ctx.clip() to constrain all drawing to the silhouette shape.
   * Includes: dark base fill, animated shimmer gradient, and mouse-following glow.
   * DO NOT MODIFY — user confirmed this looks perfect.
   */
  function fillPenguinInterior(ctx, elapsed, parallaxY) {
    if (!pathPoints || pathPoints.length < 3) return;
    ctx.save();
    ctx.translate(0, parallaxY);

    ctx.beginPath();
    ctx.moveTo(pathPoints[0].x, pathPoints[0].y);
    for (let i = 1; i < pathPoints.length; i++) {
      ctx.lineTo(pathPoints[i].x, pathPoints[i].y);
    }
    ctx.closePath();
    ctx.clip();

    ctx.fillStyle = 'rgba(8, 8, 10, 0.82)';
    ctx.fillRect(-W, -H, W * 3, H * 3);

    const pc = getPathCenter();
    const shimmerX = pc.x + Math.sin(elapsed * 0.0003) * 30;
    const shimmerY = pc.y + Math.cos(elapsed * 0.0004) * 20;
    const shimmerR = Math.min(W, H) * 0.18;
    const shimmer = ctx.createRadialGradient(shimmerX, shimmerY, 0, shimmerX, shimmerY, shimmerR);
    shimmer.addColorStop(0, 'rgba(255, 255, 255, 0.04)');
    shimmer.addColorStop(0.5, 'rgba(255, 255, 255, 0.015)');
    shimmer.addColorStop(1, 'rgba(255, 255, 255, 0)');
    ctx.fillStyle = shimmer;
    ctx.fillRect(-W, -H, W * 3, H * 3);

    if (mouseActive) {
      const mgy = mouseY - parallaxY;
      const mouseGlow = ctx.createRadialGradient(mouseX, mgy, 0, mouseX, mgy, 120);
      mouseGlow.addColorStop(0, 'rgba(255, 255, 255, 0.08)');
      mouseGlow.addColorStop(0.4, 'rgba(193, 17, 17, 0.04)');
      mouseGlow.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = mouseGlow;
      ctx.fillRect(-W, -H, W * 3, H * 3);
    }

    ctx.restore();

    // Glass border
    ctx.save();
    ctx.translate(0, parallaxY);
    ctx.beginPath();
    ctx.moveTo(pathPoints[0].x, pathPoints[0].y);
    for (let i = 1; i < pathPoints.length; i++) {
      ctx.lineTo(pathPoints[i].x, pathPoints[i].y);
    }
    ctx.closePath();
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.06)';
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.restore();
  }

  /**
   * Draw radial glow behind the penguin silhouette.
   * Pulsates slowly via sine wave on the radius. Provides depth
   * and separates the penguin from the dark background.
   */
  function drawPenguinGlow(ctx, elapsed, parallaxY) {
    const pc = getPathCenter();
    const pulseScale = 1 + Math.sin(elapsed * 0.0005) * 0.08;
    const r = Math.min(W, H) * 1.6 * pulseScale;
    const gy = pc.y + parallaxY;
    const glow = ctx.createRadialGradient(pc.x, gy, 0, pc.x, gy, r);
    glow.addColorStop(0, 'rgba(193, 17, 17, 0.12)');
    glow.addColorStop(0.3, 'rgba(193, 17, 17, 0.06)');
    glow.addColorStop(0.6, 'rgba(160, 30, 30, 0.025)');
    glow.addColorStop(1, 'rgba(0, 0, 0, 0)');
    ctx.fillStyle = glow;
    ctx.fillRect(0, 0, W, H);
  }

  /**
   * Create 16 aurora strands distributed vertically across the screen.
   * Color distribution: 1/3 bright white, 2/3 red variants.
   * White strands get higher target opacity (0.18-0.30) for visibility.
   */
  function buildAurora() {
    auroraBands = [];
    const colors = [
      redColor, softRed, brightWhite, dimRed,
      redColor, softRed, brightWhite, dimRed,
      softRed, redColor, brightWhite, dimRed,
      redColor, softRed, brightWhite, softRed
    ];
    for (let i = 0; i < 16; i++) {
      const y = H * (0.04 + (i / 16) * 0.92);
      const w = 0.8 + Math.random() * 1.8;
      const spd = 0.1 + Math.random() * 0.4;
      const amp = 15 + Math.random() * 30;
      const freq = 1.0 + Math.random() * 3.0;
      const off = i * 0.8 + Math.random() * 0.5;
      const band = new AuroraBand(y, colors[i], w, spd, amp, freq, off);
      // White strands get higher opacity
      if (colors[i] === brightWhite) {
        band.targetOpacity = 0.18 + Math.random() * 0.12;
      }
      auroraBands.push(band);
    }
  }

  // --- Shooting Star (diagonal trace from top-right to bottom-left) ---
  // Used on sub-pages only. Each star has a tapering trail rendered as
  // 6 line segments with progressive opacity/width. Stars fade out as
  // life decreases, and are removed when off-screen or life <= 0.
  class ShootingStar {
    constructor(clustered) {
      this.reset(clustered);
    }

    reset(clustered) {
      // Start from upper-right quadrant area
      var startX = W * (0.5 + Math.random() * 0.6);
      var startY = -20 - Math.random() * H * 0.3;
      if (clustered) {
        // Cluster: offset slightly from previous
        startX += (Math.random() - 0.5) * W * 0.15;
        startY += (Math.random() - 0.5) * H * 0.1;
      }
      this.x = startX;
      this.y = startY;
      // Diagonal angle: roughly top-right to bottom-left with slight variation
      var angle = Math.PI * (0.65 + Math.random() * 0.2); // ~117° to ~153°
      this.speed = 2.5 + Math.random() * 4;
      this.vx = Math.cos(angle) * this.speed;
      this.vy = Math.sin(angle) * this.speed;
      this.tailLen = 40 + Math.random() * 60;
      this.life = 1;
      this.decay = 0.004 + Math.random() * 0.006;
      this.width = 0.6 + Math.random() * 1.8;
      this.isWhite = Math.random() < 0.33;
      this.active = true;
    }

    update() {
      if (!this.active) return;
      this.x += this.vx;
      this.y += this.vy;
      this.life -= this.decay;
      if (this.life <= 0 || this.x < -100 || this.y > H + 100) {
        this.active = false;
      }
    }

    draw(ctx) {
      if (!this.active || this.life <= 0) return;
      var tailX = this.x - this.vx * this.tailLen / this.speed;
      var tailY = this.y - this.vy * this.tailLen / this.speed;

      // Draw tapering trail
      var segments = 6;
      for (var s = segments - 1; s >= 0; s--) {
        var t0 = s / segments;
        var t1 = (s + 1) / segments;
        var x0 = tailX + (this.x - tailX) * t0;
        var y0 = tailY + (this.y - tailY) * t0;
        var x1 = tailX + (this.x - tailX) * t1;
        var y1 = tailY + (this.y - tailY) * t1;
        var alpha = t1 * t1 * this.life * 0.6;
        var w = this.width * (0.15 + t1 * 0.85);

        ctx.beginPath();
        ctx.moveTo(x0, y0);
        ctx.lineTo(x1, y1);
        if (this.isWhite) {
          ctx.strokeStyle = 'rgba(255, 255, 255, ' + alpha.toFixed(3) + ')';
        } else {
          ctx.strokeStyle = 'rgba(193, 17, 17, ' + alpha.toFixed(3) + ')';
        }
        ctx.lineWidth = w;
        ctx.lineCap = 'round';
        ctx.stroke();
      }
    }
  }

  // Shooting star spawning system — uses a state machine:
  //   1. When not in a cluster: 40% chance to start a cluster, else spawn single
  //   2. During cluster: spawn 2-5 stars in quick succession (80-250ms apart)
  //   3. After cluster: long pause (3-5s) before next spawn
  //   4. Singles have 2-4s delay between them
  var shootingStars = [];
  var lastShootTime = 0;
  var nextShootDelay = 2000 + Math.random() * 3000;
  var clusterCount = 0;
  var inCluster = false;

  function spawnShootingStar(elapsed) {
    if (elapsed - lastShootTime < nextShootDelay) return;
    lastShootTime = elapsed;

    // Decide: start a cluster or single
    if (!inCluster && Math.random() < 0.4) {
      // Start a cluster of 2-5
      inCluster = true;
      clusterCount = 2 + Math.floor(Math.random() * 4);
    }

    if (inCluster) {
      shootingStars.push(new ShootingStar(true));
      clusterCount--;
      nextShootDelay = 80 + Math.random() * 250; // Quick succession in cluster
      if (clusterCount <= 0) {
        inCluster = false;
        nextShootDelay = 3000 + Math.random() * 5000; // Long pause after cluster
      }
    } else {
      shootingStars.push(new ShootingStar(false));
      nextShootDelay = 2000 + Math.random() * 4000; // Infrequent singles
    }

    // Limit total active shooting stars
    if (shootingStars.length > 20) {
      shootingStars = shootingStars.filter(function(s) { return s.active; });
    }
  }

  // --- Star field (grid-based dots with twinkle) ---
  // Used on sub-pages as the back layer, and in the homepage scroll resistance zone.
  // Stars are laid out on a uniform 30px grid with randomized size and twinkle phase.
  let stars = [];
  function buildStarField() {
    stars = [];
    const spacing = 30;
    for (let x = spacing / 2; x < W; x += spacing) {
      for (let y = spacing / 2; y < H; y += spacing) {
        stars.push({
          baseX: x, baseY: y,
          x: x, y: y,
          size: 0.8 + Math.random() * 0.8,
          twinkle: Math.random() * Math.PI * 2
        });
      }
    }
  }

  pathPoints = buildPath();
  buildGridTexture();
  buildAurora();
  buildStarField();

  let particles = []; // Rising ember particles (homepage only)

  if (isHome) {
    // Homepage: 12 tapering traces following the penguin SVG path.
    // Mixed red/white colors, staggered delays for organic feel.
    // Speeds are at half of original values for smoother movement.
    const traceConfigs = [
      { spd: 1.0, delay: 100, col: redColor, w: 2.0 },
      { spd: 0.75, delay: 400, col: redColor, w: 1.6 },
      { spd: 1.15, delay: 800, col: softRed, w: 1.4 },
      { spd: 0.9, delay: 1200, col: whiteColor, w: 1.5 },
      { spd: 0.65, delay: 200, col: dimRed, w: 1.2 },
      { spd: 0.8, delay: 600, col: redColor, w: 0.8 },
      { spd: 1.05, delay: 1000, col: softRed, w: 1.8 },
      { spd: 0.7, delay: 300, col: whiteColor, w: 1.3 },
      { spd: 0.95, delay: 700, col: redColor, w: 1.0 },
      { spd: 1.2, delay: 1100, col: dimRed, w: 1.6 },
      { spd: 0.85, delay: 500, col: whiteColor, w: 1.1 },
      { spd: 0.6, delay: 900, col: softRed, w: 0.7 },
    ];
    traceConfigs.forEach(function(c) {
      traces.push(new Trace(pathPoints, c.spd, c.delay, c.col, c.w));
    });
  } else {
    // Sub-pages: no text traces, just shooting stars + stars + aurora
    buildStarField();
  }

  // ============================================
  //  ANIMATION LOOP
  // ============================================
  const startTime = performance.now();
  let lastFrame = 0;
  const TARGET_FPS = 30;       // Cap framerate for performance
  const FRAME_TIME = 1000 / TARGET_FPS;

  /**
   * Main render loop — called via requestAnimationFrame.
   * Throttled to ~30fps. Renders different layer stacks based on isHome.
   */
  function animate(now) {
    requestAnimationFrame(animate);

    if (now - lastFrame < FRAME_TIME) return;
    lastFrame = now;

    const elapsed = now - startTime;

    // Parallax offsets — strands move slower than penguin for depth illusion
    const parallaxStrands = -scrollY * 0.075;  // Aurora strands depth
    const parallaxPenguin = -scrollY * 0.125;  // Penguin/traces depth

    ctx.clearRect(0, 0, W, H);

    // Draw subtle dot grid background
    if (gridCanvas) {
      ctx.drawImage(gridCanvas, 0, 0);
    }

    // 1. Draw aurora strands with parallax
    ctx.save();
    ctx.translate(0, parallaxStrands);
    auroraBands.forEach(function(b) {
      b.update(elapsed);
      b.draw(ctx, elapsed, W, H);
    });
    ctx.restore();

    if (isHome) {
      // 2. Brighter glow behind penguin (with parallax)
      drawPenguinGlow(ctx, elapsed, parallaxPenguin);

      // 3. Frosted glass interior (with parallax)
      fillPenguinInterior(ctx, elapsed, parallaxPenguin);

      // 4. Draw logo traces ON TOP (with parallax)
      if (traces.length > 0) {
        ctx.save();
        ctx.translate(0, parallaxPenguin);
        traces.forEach(function(t) {
          t.update(elapsed);
          t.draw(ctx);
        });
        ctx.restore();
      }

      // 5. Spawn rising particles from trace positions
      if (traces.length > 0 && particles.length < 80 && Math.random() < 0.3) {
        var randomTrace = traces[Math.floor(Math.random() * traces.length)];
        if (randomTrace.active) {
          var headIdx = Math.floor(randomTrace.progress) % randomTrace.pathLen;
          var pt = randomTrace.pathPoints[headIdx];
          particles.push(new Particle(pt.x, pt.y + parallaxPenguin));
        }
      }

      // Update and draw particles
      ctx.save();
      for (var pi = particles.length - 1; pi >= 0; pi--) {
        particles[pi].update();
        if (particles[pi].life <= 0) {
          particles.splice(pi, 1);
        } else {
          particles[pi].draw(ctx);
        }
      }
      ctx.restore();

      // 6. Mouse proximity ripple
      if (mouseActive) {
        var rippleR = 60 + Math.sin(elapsed * 0.003) * 10;
        var ripple = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, rippleR);
        ripple.addColorStop(0, 'rgba(193, 17, 17, 0.04)');
        ripple.addColorStop(0.6, 'rgba(255, 255, 255, 0.02)');
        ripple.addColorStop(1, 'rgba(0, 0, 0, 0)');
        ctx.fillStyle = ripple;
        ctx.fillRect(0, 0, W, H);
      }

    } else {
      // Sub-pages: layered effects — stars (back), aurora (already drawn above), shooting stars (front)

      // Stars on sub-pages (always visible, not scroll-gated)
      // Performance: batch stars by similar alpha into fewer draw calls
      var mouseInfluenceSub = 80;
      var starBatch = [];
      for (var si2 = 0; si2 < stars.length; si2++) {
        var s2 = stars[si2];
        var sx2 = s2.baseX;
        var sy2 = s2.baseY;
        if (mouseActive) {
          var mdx2 = sx2 - mouseX;
          var mdy2 = sy2 - mouseY;
          var mDist2 = mdx2 * mdx2 + mdy2 * mdy2;
          var mouseInfSq = mouseInfluenceSub * mouseInfluenceSub;
          if (mDist2 < mouseInfSq && mDist2 > 0) {
            var mDistReal = Math.sqrt(mDist2);
            var force2 = (1 - mDistReal / mouseInfluenceSub) * 15;
            sx2 += (mdx2 / mDistReal) * force2;
            sy2 += (mdy2 / mDistReal) * force2;
          }
        }
        s2.x = sx2;
        s2.y = sy2;
        var twinkle2 = 0.15 + 0.2 * Math.sin(elapsed * 0.002 + s2.twinkle);
        starBatch.push({ x: s2.x, y: s2.y, size: s2.size * 0.7, alpha: twinkle2 });
      }
      // Draw all stars in a single pass, grouped by approximate alpha
      ctx.fillStyle = 'rgba(255, 255, 255, 0.25)';
      ctx.beginPath();
      for (var sbi = 0; sbi < starBatch.length; sbi++) {
        var sb = starBatch[sbi];
        ctx.moveTo(sb.x + sb.size, sb.y);
        ctx.arc(sb.x, sb.y, sb.size, 0, Math.PI * 2);
      }
      ctx.fill();

      // Shooting stars (front layer, on top of aurora)
      spawnShootingStar(elapsed);
      for (var ssi = shootingStars.length - 1; ssi >= 0; ssi--) {
        shootingStars[ssi].update();
        if (!shootingStars[ssi].active) {
          shootingStars.splice(ssi, 1);
        } else {
          shootingStars[ssi].draw(ctx);
        }
      }
    }
  }

  requestAnimationFrame(animate);

  // Rebuild all size-dependent resources on window resize
  window.addEventListener('resize', function() {
    resize();
    pathPoints = buildPath();
    buildGridTexture();
    buildStarField();
    if (isHome) {
      // Update trace path references to the new scaled points
      traces.forEach(function(t) {
        t.pathPoints = pathPoints;
        t.pathLen = pathPoints.length;
      });
    }
    buildAurora();
  });
})();
</script>
