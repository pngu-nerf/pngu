---
/**
 * BackgroundEffects.astro — full-screen canvas behind every page.
 *
 * Two overlaid layers, both visible from page load (no fade-in/transition):
 *   - Aurora "strands"  — white horizontal sine waves, clipped to the
 *                          area *outside* the logo silhouette so the
 *                          mark's interior reads as negative space.
 *   - Logo traces        — slither.io-style "snake" trails along the
 *                          PNGU mark path. Each trace is one stroked
 *                          line through ~80 consecutive path points
 *                          with lineCap=round and lineJoin=round — the
 *                          single path keeps thickness uniform and the
 *                          round caps give natural pill ends. No
 *                          gradient, no shadowBlur, no tapering.
 *
 * Rendering details:
 *   - One offscreen dot-grid texture, blitted each frame.
 *   - 30 FPS cap to keep mobile CPU usage modest.
 *   - The grain overlay is a CSS-only SVG (no image request).
 *   - The aurora clip uses an evenodd fill rule: full-canvas rect + logo
 *     path. Inside the logo, winding number is 2 → excluded.
 *
 * The script duplicates the logo path data from <Logo />. Keeping a
 * string copy avoids reading the inline <svg> from the DOM before paint.
 */
---

<canvas id="bg-canvas"></canvas>
<div id="grain-overlay"></div>

<style>
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    background: #000;
  }
  #grain-overlay {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }
</style>

<script is:inline>
  (function () {
    const canvas = document.getElementById('bg-canvas');
    if (!canvas) return;

    // Don't burn CPU / battery on users who opted out of motion, or on
    // metered/slow connections (Save-Data header / saveData hint). The grain
    // overlay and CSS background still render; only the JS animation is
    // skipped.
    const reduceMotion =
      window.matchMedia &&
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData =
      (navigator.connection && navigator.connection.saveData) === true;
    if (reduceMotion || saveData) return;

    const ctx = canvas.getContext('2d');

    let W, H;
    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // PNGU mark path — kept in sync with src/components/Logo.astro.
    const LOGO_PATH = 'M740.999,478.013 C732.574,479.445 726.913,485.562 720.161,489.579 C712.414,494.187 704.845,499.102 697.298,504.036 C692.012,507.492 686.547,510.801 681.777,514.892 C674.551,521.090 667.873,527.928 660.935,534.464 C654.627,540.404 648.340,546.368 641.928,552.195 C639.013,554.844 635.485,556.876 632.823,559.735 C627.664,565.276 622.951,571.231 617.999,576.966 C611.902,584.025 605.341,590.729 599.758,598.169 C595.680,603.603 591.923,609.316 589.345,615.895 C586.196,623.934 581.278,631.263 577.628,639.132 C575.564,643.581 574.522,648.502 572.996,653.202 C571.465,657.920 569.905,662.628 568.356,667.339 C568.256,667.642 568.004,667.957 568.045,668.234 C569.180,675.956 563.976,674.825 559.098,675.090 C545.363,675.834 531.422,675.836 518.020,678.466 C510.688,679.905 503.644,679.769 496.516,679.888 C461.607,680.469 426.579,679.030 391.812,681.458 C356.639,683.914 321.572,682.024 286.473,682.919 C257.736,683.651 228.980,683.617 200.234,684.019 C184.150,684.245 168.069,684.716 151.986,684.988 C129.572,685.368 107.157,685.739 84.741,685.946 C79.477,685.995 75.828,682.500 72.505,678.891 C71.964,678.304 71.809,676.901 72.095,676.095 C73.272,672.776 74.624,669.514 76.028,666.282 C79.981,657.187 83.997,648.119 87.978,639.036 C92.523,628.667 97.115,618.317 101.567,607.908 C103.141,604.229 104.237,600.347 105.774,596.651 C109.775,587.026 113.968,577.481 117.948,567.847 C120.196,562.404 122.038,556.792 124.309,551.358 C127.095,544.691 130.291,538.194 133.020,531.504 C134.939,526.798 136.209,521.830 138.071,517.098 C139.877,512.507 141.862,507.960 144.139,503.587 C147.600,496.940 151.181,490.338 155.090,483.949 C158.234,478.810 162.091,474.112 165.357,469.042 C169.395,462.771 172.954,456.189 177.079,449.979 C181.603,443.167 186.668,436.715 191.241,429.934 C194.070,425.740 196.243,421.106 199.027,416.879 C203.584,409.962 208.472,403.264 213.075,396.376 C215.326,393.009 216.687,388.884 219.421,386.033 C229.376,375.650 239.777,365.698 249.936,355.509 C256.358,349.067 262.390,342.209 269.107,336.098 C272.430,333.075 276.849,331.217 280.868,329.007 C290.026,323.972 299.206,318.976 308.446,314.095 C316.772,309.695 324.964,304.916 333.647,301.360 C339.508,298.959 346.158,298.540 352.385,296.958 C359.025,295.271 365.667,293.512 372.154,291.330 C382.317,287.911 392.847,287.437 403.361,287.054 C426.521,286.213 449.703,285.931 472.853,284.882 C483.476,284.400 493.720,285.910 504.024,287.915 C507.539,288.599 511.188,288.584 514.769,288.950 C521.210,289.609 527.711,289.960 534.066,291.113 C539.058,292.019 543.933,293.752 548.738,295.463 C553.265,297.075 557.640,299.117 562.066,301.007 C566.924,303.081 571.821,305.076 576.597,307.327 C582.149,309.943 587.534,312.913 593.089,315.523 C600.764,319.129 609.275,321.490 616.071,326.301 C624.695,332.407 634.338,336.107 643.456,341.000 C654.417,346.882 665.312,352.890 676.352,358.620 C681.614,361.350 687.229,363.394 692.531,366.053 C698.779,369.185 704.857,372.654 711.020,375.957 C711.783,376.366 712.597,376.916 713.411,376.959 C721.158,377.360 728.908,377.735 736.662,377.984 C748.910,378.377 761.167,378.531 773.410,379.040 C785.084,379.525 796.741,380.404 808.412,380.978 C817.490,381.424 826.582,381.588 835.662,382.019 C848.105,382.610 860.547,383.264 872.977,384.082 C874.690,384.195 876.413,385.251 877.992,386.124 C884.449,389.693 890.880,393.313 897.263,397.013 C899.923,398.555 902.505,400.252 905.010,402.037 C910.838,406.190 917.701,408.722 922.423,414.653 C927.559,421.104 933.497,426.916 939.744,433.723 C930.994,434.880 922.980,435.952 914.962,436.997 C907.107,438.020 898.921,437.982 891.489,440.334 C885.024,442.380 878.619,442.033 872.225,442.975 C864.687,444.085 857.104,444.899 849.573,446.050 C844.327,446.852 839.135,448.016 833.916,448.999 C828.536,450.013 823.152,451.007 817.768,452.002 C812.061,453.055 806.188,453.567 800.686,455.277 C793.217,457.600 786.012,460.787 778.730,463.693 C771.333,466.646 764.039,469.867 756.587,472.669 C751.510,474.578 746.238,475.968 740.999,478.013 Z';

    // Sample N points along the SVG path, normalized into [0,1]^2.
    function sampleSVGPath(pathD, numSamples) {
      const ns = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(ns, 'svg');
      svg.setAttribute('viewBox', '0 0 1000 1000');
      svg.style.position = 'absolute';
      svg.style.width = '0';
      svg.style.height = '0';
      svg.style.overflow = 'hidden';
      const path = document.createElementNS(ns, 'path');
      path.setAttribute('d', pathD);
      svg.appendChild(path);
      document.body.appendChild(svg);

      const total = path.getTotalLength();
      const raw = [];
      for (let i = 0; i < numSamples; i++) {
        const pt = path.getPointAtLength((i / numSamples) * total);
        raw.push({ x: pt.x, y: pt.y });
      }
      document.body.removeChild(svg);

      let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
      raw.forEach((p) => {
        if (p.x < minX) minX = p.x;
        if (p.x > maxX) maxX = p.x;
        if (p.y < minY) minY = p.y;
        if (p.y > maxY) maxY = p.y;
      });
      const bw = maxX - minX || 1;
      const bh = maxY - minY || 1;
      return raw.map((p) => ({ x: (p.x - minX) / bw, y: (p.y - minY) / bh }));
    }

    // Scale a normalized path to (cx, cy) at (scaleW, scaleH) in screen space.
    function scalePath(normPts, cx, cy, scaleW, scaleH) {
      return normPts.map((p) => ({
        x: cx + (p.x - 0.5) * scaleW,
        y: cy + (p.y - 0.5) * scaleH,
      }));
    }

    // Slow horizontal sine wave — used for the off-home ambient bands.
    class AuroraBand {
      constructor(y, color, width, speed, amp, freq, offset) {
        this.baseY = y;
        this.color = color;
        this.width = width;
        this.speed = speed;
        this.amp = amp;
        this.freq = freq;
        this.offset = offset;
        this.opacity = 0;
        this.targetOpacity = 0.12 + Math.random() * 0.1;
      }
      update() {
        if (this.opacity < this.targetOpacity) this.opacity += 0.002;
      }
      draw(ctx, time, W, H) {
        if (this.opacity < 0.01) return;
        ctx.beginPath();
        const steps = 40;
        for (let i = 0; i <= steps; i++) {
          const t = i / steps;
          const x = t * W;
          const wave =
            Math.sin(t * this.freq + time * this.speed * 0.0008 + this.offset) *
            this.amp;
          const y = this.baseY + wave;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = this.color.replace('ALPHA', this.opacity.toFixed(3));
        ctx.lineWidth = this.width;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.stroke();
      }
    }

    // A snake-like trail along the logo path. Rendered as a single
    // stroked line through TRAIL consecutive path points with lineCap
    // and lineJoin set to "round". One stroke = uniform thickness with
    // no visible seams between segments, and the round caps give clean
    // pill ends at head and tail. lineWidth = radius * 2 so `radius`
    // still reads as "half the body thickness".
    class Trace {
      constructor(pathPoints, speed, delay, color, radius) {
        this.pathPoints = pathPoints;
        this.pathLen = pathPoints.length;
        this.speed = speed;
        this.delay = delay;
        this.color = color;
        this.radius = radius;
        this.progress = Math.random() * pathPoints.length;
        this.active = false;
      }
      update(time) {
        if (time < this.delay) return;
        this.active = true;
        this.progress += this.speed;
        if (this.progress >= this.pathLen) this.progress -= this.pathLen;
      }
      draw(ctx) {
        if (!this.active) return;
        const headIdx = Math.floor(this.progress) % this.pathLen;
        const TRAIL = 80;            // path points covered by the body
        // Walk tail→head so the resulting subpath's "head end" is the
        // moving tip (the last lineTo). The round cap there reads as the
        // snake's nose.
        ctx.beginPath();
        for (let i = TRAIL - 1; i >= 0; i--) {
          const idx = (headIdx - i + this.pathLen) % this.pathLen;
          const p = this.pathPoints[idx];
          if (i === TRAIL - 1) ctx.moveTo(p.x, p.y);
          else ctx.lineTo(p.x, p.y);
        }
        ctx.strokeStyle = this.color.replace('ALPHA', '1');
        ctx.lineWidth = this.radius * 2;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.stroke();
      }
    }

    const normPoints = sampleSVGPath(LOGO_PATH, 300);
    const redColor = 'rgba(193, 17, 17, ALPHA)';
    const whiteColor = 'rgba(255, 255, 255, ALPHA)';

    let traces = [];
    let auroraBands = [];
    let pathPoints;

    // Offscreen dot grid — drawn once on resize, blitted each frame.
    let gridCanvas = null;
    function buildGridTexture() {
      gridCanvas = document.createElement('canvas');
      gridCanvas.width = W;
      gridCanvas.height = H;
      const gc = gridCanvas.getContext('2d');
      gc.fillStyle = 'rgba(255, 255, 255, 0.015)';
      const spacing = 40;
      for (let x = spacing; x < W; x += spacing) {
        for (let y = spacing; y < H; y += spacing) {
          gc.beginPath();
          gc.arc(x, y, 0.6, 0, Math.PI * 2);
          gc.fill();
        }
      }
    }

    function buildPath() {
      // Logo bounding-box aspect ≈ 2.16. Anchored at the visual centre of
      // the viewport — the penguin "head" of the mark sits on screen centre.
      const aspect = 2.16;
      const targetH = H * 0.5;
      const targetW = targetH * aspect;
      const finalW = Math.min(targetW, W * 0.85);
      const finalH = finalW / aspect;
      const cx = W * 0.5;
      const cy = H * 0.5;
      pathPoints = scalePath(normPoints, cx, cy, finalW, finalH);
      return pathPoints;
    }

    function buildAurora() {
      auroraBands = [];
      // All bands are white — they read as soft glowing threads behind the
      // logo rather than competing with the red brand accents on-page.
      const yPositions = [0.12, 0.3, 0.5, 0.82];
      for (let i = 0; i < 4; i++) {
        auroraBands.push(
          new AuroraBand(
            H * yPositions[i],
            whiteColor,
            2.5 + Math.random() * 2.5, // thicker strands (was 1–2.5)
            0.2 + Math.random() * 0.3,
            10 + Math.random() * 15,
            1.5 + Math.random() * 2,
            i * 1.5
          )
        );
      }
    }

    pathPoints = buildPath();
    buildGridTexture();
    buildAurora();

    // Four solid-coloured snakes ride the logo path. Mixed speeds + start
    // delays keep them from stacking; alternating red/white so the brand
    // accent reads cleanly without the two old softer reds muddying it.
    traces.push(new Trace(pathPoints, 2.0, 100,  redColor,   11));
    traces.push(new Trace(pathPoints, 1.5, 500,  whiteColor,  9));
    traces.push(new Trace(pathPoints, 2.3, 1000, redColor,   10));
    traces.push(new Trace(pathPoints, 1.8, 1500, whiteColor,  8));

    const startTime = performance.now();
    let lastFrame = 0;
    const FRAME_TIME = 1000 / 30; // cap at 30 fps

    // Stroke a closed Path2D-style outline of the logo onto the current
    // ctx path, given the current pathPoints. Used both for the evenodd
    // aurora clip and would be reusable elsewhere.
    function appendLogoPath() {
      const pts = pathPoints;
      ctx.moveTo(pts[0].x, pts[0].y);
      for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x, pts[i].y);
      ctx.closePath();
    }

    function animate(now) {
      requestAnimationFrame(animate);
      if (now - lastFrame < FRAME_TIME) return;
      lastFrame = now;

      const elapsed = now - startTime;
      ctx.clearRect(0, 0, W, H);
      if (gridCanvas) ctx.drawImage(gridCanvas, 0, 0);

      // Aurora layer — clipped to "everywhere except inside the logo
      // silhouette" so the mark's interior reads as clean negative space.
      // Evenodd fill rule: full-canvas rect (winding 1) + logo path
      // (winding 2 inside the logo) → odd region = outside logo.
      ctx.save();
      ctx.beginPath();
      ctx.rect(0, 0, W, H);
      appendLogoPath();
      ctx.clip('evenodd');
      auroraBands.forEach((b) => {
        b.update();
        b.draw(ctx, elapsed, W, H);
      });
      ctx.restore();

      // Logo traces — unclipped, drawn over the punched-out aurora area.
      traces.forEach((t) => {
        t.update(elapsed);
        t.draw(ctx);
      });
    }

    requestAnimationFrame(animate);

    window.addEventListener('resize', () => {
      pathPoints = buildPath();
      buildGridTexture();
      buildAurora();
      // Re-point all traces at the rebuilt path (same array length).
      traces.forEach((t) => {
        t.pathPoints = pathPoints;
        t.pathLen = pathPoints.length;
      });
    });
  })();
</script>
